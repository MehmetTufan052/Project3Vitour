            document.querySelectorAll('.row-pdf-btn').forEach(function(btn){
                btn.addEventListener('click', function(e){
                    e.stopPropagation();
                    exportSingleRow(btn.closest('tr'), 'pdf');
                });
            });

            // Checkbox — tümü
            document.getElementById('checkAll').addEventListener('change', function(){
                document.querySelectorAll('.row-chk').forEach(function(cb){
                    cb.checked = document.getElementById('checkAll').checked;
                });
                updateSelExportBtn();
            });
            document.querySelectorAll('.row-chk').forEach(function(cb){
                cb.addEventListener('change', updateSelExportBtn);
            });

            // Hero hızlı butonlar
            document.getElementById('quickXlBtn').addEventListener('click', exportBulkExcel);
            document.getElementById('quickPdfBtn').addEventListener('click', exportBulkPdf);

            // Export kart tıklama event (buton zaten onclick'li, kart tıklamasını önle)
            document.querySelectorAll('.rp-exp-card').forEach(function(card){
                card.addEventListener('click', function(e){
                    if (e.target.closest('.rp-exp-btn')) return;
                });
            });

            // Global expose
            window.applyRpFilter  = applyRpFilter;
            window.clearRpFilter  = clearRpFilter;
            window.exportBulkExcel= exportBulkExcel;
            window.exportBulkPdf  = exportBulkPdf;
            window.exportCsv      = exportCsv;
            window.exportSelected = exportSelected;
            window.rpChangePage   = rpChangePage;
            window.rpGoPage       = rpGoPage;

            // İlk render
            Array.from(document.querySelectorAll('#rpBody tr')).forEach(function(r){
                r.dataset.filtered = 'false';
            });
            applyRpFilter();
        });
    </script>
}
