        /* ════════════════════════════════════════════
           LOADING STATE
        ════════════════════════════════════════════ */
        var _expOriginals = {};
        function setExportLoading(btnId, loading) {
            var btn = document.getElementById(btnId);
            if (!btn) return;
            if (loading) {
                _expOriginals[btnId] = btn.innerHTML;
                btn.innerHTML = '<span class="exp-spinner"></span> Hazırlanıyor…';
                btn.disabled  = true;
            } else {
                btn.innerHTML = _expOriginals[btnId] || btn.innerHTML;
                btn.disabled  = false;
            }
        }

