        /* SheetJS CDN'den yükle (sayfa açılışında bir kez) */
        (function loadSheetJS() {
            if (window.XLSX) return;
            var s = document.createElement('script');
            s.src = 'https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js';
            s.async = true;
            document.head.appendChild(s);
        })();

        function waitForXLSX(cb) {
            if (window.XLSX) { cb(); return; }
            var t = setInterval(function() {
                if (window.XLSX) { clearInterval(t); cb(); }
            }, 80);
        }

        /* Sütun seçimi */
        function getActiveCols(fields) {
            var allCols = [
                { label: 'Rezervasyon Kodu', key: 'code'    },
                { label: 'Ad Soyad',         key: 'name'    },
                { label: 'E-posta',          key: 'email'   },
                { label: 'Telefon',          key: 'phone'   },
                { label: 'Tur',              key: 'tour'    },
                { label: 'Tarih',            key: 'date'    },
                { label: 'Kişi Sayısı',      key: 'persons' },
                { label: 'Toplam Tutar (₺)', key: 'price'   },
                { label: 'Şehir',            key: 'city'    },
                { label: 'Ülke',             key: 'country' },
                { label: 'Durum',            key: 'status'  }
            ];
            var basicKeys     = ['code','name','tour','date','persons','status'];
            var financialKeys = ['code','name','tour','price','persons'];
            var contactKeys   = ['name','email','phone','city','country'];
            if (fields === 'basic')     return allCols.filter(function(c){ return basicKeys.indexOf(c.key)     > -1; });
            if (fields === 'financial') return allCols.filter(function(c){ return financialKeys.indexOf(c.key) > -1; });
            if (fields === 'contact')   return allCols.filter(function(c){ return contactKeys.indexOf(c.key)   > -1; });
            return allCols;
        }

        /* Veri dizisinden XLSX workbook üret */
        function buildXlsx(dataArr, sheetTitle) {
            var fields = document.getElementById('expFields').value;
            var sortBy = document.getElementById('expSort').value;
            var cols   = getActiveCols(fields);

            /* Sırala */
            dataArr.sort(function(a, b) {
                if (sortBy === 'name')  return (a.name||'').localeCompare(b.name||'', 'tr');
                if (sortBy === 'price') return parseFloat(b.price||0) - parseFloat(a.price||0);
                return (a.date||'').localeCompare(b.date||'');
            });

            var XLSX = window.XLSX;
            var wb   = XLSX.utils.book_new();
            var now  = new Date().toLocaleDateString('tr-TR');

            /* ── Veri sayfası ── */
            var wsData = [];

            /* Başlık satırları */
            wsData.push(['VİTOUR REZERVASYON RAPORU', '', 'Oluşturma: ' + now]);
            wsData.push(['Toplam Kayıt:', dataArr.length, '']);
            wsData.push([]);   /* boş satır */

            /* Kolon başlıkları */
            wsData.push(cols.map(function(c){ return c.label; }));

            /* Veri satırları */
            var totalPrice = 0;
            dataArr.forEach(function(d) {
                var p = parseFloat(d.price) || 0;
                totalPrice += p;
                wsData.push(cols.map(function(c) {
                    if (c.key === 'price')   return p;             /* sayı olarak */
                    if (c.key === 'persons') return parseInt(d.persons) || 0;
                    return d[c.key] || '';
                }));
            });

            /* Toplam satırı */
            wsData.push([]);
            var totRow = new Array(cols.length).fill('');
            totRow[0]  = 'GENEL TOPLAM';
            var priceIdx = cols.findIndex(function(c){ return c.key === 'price'; });
            if (priceIdx > -1) totRow[priceIdx] = totalPrice;
            wsData.push(totRow);

            var ws = XLSX.utils.aoa_to_sheet(wsData);

            /* Sütun genişlikleri */
            var colWidths = cols.map(function(c) {
                var maxLen = c.label.length;
                dataArr.forEach(function(d) {
                    var val = String(d[c.key] || '');
                    if (val.length > maxLen) maxLen = val.length;
                });
                return { wch: Math.min(maxLen + 4, 45) };
            });
            ws['!cols'] = colWidths;

            /* Tutar sütunu sayı formatı */
            if (priceIdx > -1) {
                var colLetter = XLSX.utils.encode_col(priceIdx);
                for (var ri = 4; ri < wsData.length; ri++) {
                    var cellAddr = colLetter + (ri + 1);
                    if (ws[cellAddr] && typeof ws[cellAddr].v === 'number') {
                        ws[cellAddr].t = 'n';
                        ws[cellAddr].z = '#,##0.00" ₺"';
                    }
                }
            }

            XLSX.utils.book_append_sheet(wb, ws, sheetTitle || 'Rezervasyonlar');

            /* ── Özet sayfası ── */
            var summaryData = [
                ['VİTOUR — ÖZET RAPORU', ''],
                ['Oluşturma Tarihi', now],
                [''],
                ['Metrik', 'Değer'],
                ['Toplam Rezervasyon', dataArr.length],
                ['Toplam Gelir (₺)',   totalPrice],
                ['Ortalama Tutar (₺)', dataArr.length > 0 ? (totalPrice / dataArr.length) : 0],
                [''],
                ['Durum Dağılımı', ''],
                ['Aktif',      dataArr.filter(function(d){ return d.status === 'Aktif'; }).length],
                ['Yakında',    dataArr.filter(function(d){ return d.status === 'Yakında'; }).length],
                ['Bugün',      dataArr.filter(function(d){ return d.status === 'Bugün'; }).length],
                ['Tamamlandı', dataArr.filter(function(d){ return d.status === 'Tamamlandı'; }).length]
            ];
            var wsSummary = XLSX.utils.aoa_to_sheet(summaryData);
            wsSummary['!cols'] = [{wch:28},{wch:20}];
            XLSX.utils.book_append_sheet(wb, wsSummary, 'Özet');

            return wb;
        }

