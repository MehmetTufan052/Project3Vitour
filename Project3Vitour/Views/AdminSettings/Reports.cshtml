            // Satır bazlı butonlar
            document.querySelectorAll('.row-xl-btn').forEach(function(btn){
                btn.addEventListener('click', function(e){
                    e.stopPropagation();
                    exportSingleRow(btn.closest('tr'), 'excel');
                });
