                    </div>
                </div>
            </div>
        </div>

    </div><!-- /set-panels -->
</div><!-- /set-shell -->

<script>
    function switchPanel(id, el) {
        // nav items
        document.querySelectorAll('.sn-item').forEach(i => i.classList.remove('active'));
        el.classList.add('active');
        // panels
        document.querySelectorAll('.set-panel').forEach(p => p.classList.remove('active'));
        document.getElementById('panel-' + id).classList.add('active');
    }

    function previewAvatar(e) {
        const file = e.target.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = function(ev) {
            const img = document.getElementById('auImg');
            img.src = ev.target.result;
            img.style.display = 'block';
            document.getElementById('auPreview').style.fontSize = '0';
        };
        reader.readAsDataURL(file);
    }

    function pickSwatch(el) {
        document.querySelectorAll('.swatch').forEach(s => s.classList.remove('picked'));
        el.classList.add('picked');
        showToast('Tema rengi önizlemesi seçildi.', 'i');
    }
</script>


