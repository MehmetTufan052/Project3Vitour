                        </div>
                    </div>
                    <div class="sg-row">
                        <div class="sf">
                            <label>Yeni Şifre <span class="req">*</span></label>
                            <input type="password" placeholder="••••••••" />
                        </div>
                        <div class="sf">
                            <label>Yeni Şifre (Tekrar) <span class="req">*</span></label>
                            <input type="password" placeholder="••••••••" />
                        </div>
                    </div>

                    <!-- Strength bar -->
                    <div class="sf">
                        <label>Şifre Gücü</label>
                        <div style="display:flex;gap:5px;margin-top:2px">
                            <div style="flex:1;height:4px;border-radius:4px;background:#e2e8f0"></div>
                            <div style="flex:1;height:4px;border-radius:4px;background:#e2e8f0"></div>
                            <div style="flex:1;height:4px;border-radius:4px;background:#e2e8f0"></div>
                            <div style="flex:1;height:4px;border-radius:4px;background:#e2e8f0"></div>
                        </div>
