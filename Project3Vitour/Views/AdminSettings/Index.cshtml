            </div>
        </div>

        <!-- ── SECURITY ── -->
        <div class="set-panel" id="panel-security">
            <div class="sp-card">
                <div class="sp-head">
                    <div class="sp-head-ic cyan"><i class="fa-solid fa-shield-halved"></i></div>
                    <div class="sp-head-info">
