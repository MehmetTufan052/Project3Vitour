            </div>
        </div>

        <!-- ── DANGER ZONE ── -->
        <div class="set-panel" id="panel-danger">
            <div class="sp-card">
                <div class="sp-head">
                    <div class="sp-head-ic rose"><i class="fa-solid fa-triangle-exclamation"></i></div>
