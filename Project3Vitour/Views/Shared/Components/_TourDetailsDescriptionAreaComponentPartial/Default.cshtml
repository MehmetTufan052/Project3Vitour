<div class="row">
    <div class="col-lg-8">
        <div class="information-content-tour">
            @{
                var isCappadociaTour =
                    (Model.Title?.IndexOf("Kapadokya", StringComparison.OrdinalIgnoreCase) ?? -1) >= 0 ||
                    (Model.Title?.IndexOf("Cappadocia", StringComparison.OrdinalIgnoreCase) ?? -1) >= 0;
                var formattedDescription = (Model.Description ?? string.Empty)
                    .Replace("Dünyanın Başka Hiçbir Yerinde Göremeyeceğiniz Bir Sabah", "<span class=\"description\">Dünyanın Başka Hiçbir Yerinde Göremeyeceğiniz Bir Sabah</span>");
            }
            <div class="description-wrap mb-40">
                @Html.Raw(formattedDescription)
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="side-bar-right">
            <div class="sidebar-widget">
                <h6 class="block-heading">Book With Confidence</h6>
                <ul class="category-confidence">
                    <li class="flex-three">
                        <i class="icon-customer-service-1"></i>
                        <span>Customer care available 24/7</span>
                    </li>
                    <li class="flex-three">
                        <i class="icon-Vector-6"></i>
                        <span>Hand-picked Tours & Activities</span>
                    </li>
                    <li class="flex-three">
                        <i class="icon-insurance-1"></i>
                        <span>Free Travel Insureance</span>
                    </li>
                    <li class="flex-three">
                        <i class="icon-price-tag-1-1"></i>
                        <span>No-hassle best price guarantee</span>
                    </li>
                </ul>
            </div>
            @await Component.InvokeAsync("_TourDetailLast3TourComponentPartial", new { tourId = Model.TourId })
        </div>
    </div>
</div>

