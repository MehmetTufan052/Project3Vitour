@model GetTourByIdDto
@using System.Text.RegularExpressions

<div class="row">
    <div class="col-lg-8">
        <div class="information-content-tour">
            @{
                var descriptionContent = !string.IsNullOrWhiteSpace(Model?.LongDescription)
                    ? Model.LongDescription
                    : Model?.Description ?? string.Empty;
                descriptionContent = Regex.Replace(descriptionContent, "<[^>]*$", string.Empty, RegexOptions.Singleline);
                var formattedDescription = descriptionContent
                    .Replace("Dünyanın Başka Hiçbir Yerinde Göremeyeceğiniz Bir Sabah", "<span class=\"description\">Dünyanın Başka Hiçbir Yerinde Göremeyeceğiniz Bir Sabah</span>");
            }
            <div class="description-wrap mb-40">
                @Html.Raw(formattedDescription)
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="side-bar-right">
            <div class="sidebar-widget">
                <h6 class="block-heading">Gonul Rahatligiyla Rezervasyon Yapin</h6>
                <ul class="category-confidence">
                    <li class="flex-three">
                        <i class="icon-customer-service-1"></i>
                        <span>7/24 musteri destegi</span>
                    </li>
                    <li class="flex-three">
                        <i class="icon-Vector-6"></i>
                        <span>Ozenle secilmis tur ve aktiviteler</span>
                    </li>
                    <li class="flex-three">
                        <i class="icon-insurance-1"></i>
                        <span>Ucretsiz seyahat sigortasi</span>
                    </li>
                    <li class="flex-three">
                        <i class="icon-price-tag-1-1"></i>
                        <span>Sorunsuz en iyi fiyat garantisi</span>
                    </li>
                </ul>
                <a href="#" class="btn-main" style="margin-top: 24px; width: 100%; text-align: center;">Randevu Al</a>
            </div>
            @await Component.InvokeAsync("_TourDetailLast3TourComponentPartial", new { tourId = Model.TourId })
        </div>
    </div>
</div>
