@model List<ResultTourPlanDto>

<div class="tab-pane fade" id="pills-tour-planing" role="tabpanel"
     aria-labelledby="pills-tour-planing-tab" tabindex="0">

    <div class="row">
        <div class="col-lg-8">
            <div class="planing-content-tour">
                <h3 class="title-plan">Tur Plani :</h3>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <div class="tour-planing-section flex">
                            <div class="number-box flex-five">0 @item.NumberOfDay</div>
                            <div class="content-box">
                                <h5 class="title">@item.DayTitle</h5>
                                <p class="des">
                                    @Html.Raw(item.Description)
                                </p>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div style="padding:24px;border:1px dashed #dbe2ea;border-radius:16px;background:#f8fbff;color:#5b6878;">
                        Bu tur icin henuz gunluk plan bilgisi eklenmemis.
                    </div>
                }
            </div>

        </div>
        <div class="col-lg-4">
            <div class="side-bar-right">
                <div class="sidebar-widget">
                    <h6 class="block-heading">Gonul Rahatligiyla Rezervasyon Yapin</h6>
                    <ul class="category-confidence">
                        <li class="flex-three">
                            <i class="icon-customer-service-1"></i>
                            <span>7/24 musteri destegi</span>
                        </li>
                        <li class="flex-three">
                            <i class="icon-Vector-6"></i>
                            <span>Ozenle secilmis tur ve aktiviteler</span>
                        </li>
                        <li class="flex-three">
                            <i class="icon-insurance-1"></i>
                            <span>Ucretsiz seyahat sigortasi</span>
                        </li>
                        <li class="flex-three">
                            <i class="icon-price-tag-1-1"></i>
                            <span>Sorunsuz en iyi fiyat garantisi</span>
                        </li>
                    </ul>
                    <a href="/Reservation/CreateReservation" class="btn-main" style="margin-top: 24px; width: 100%; text-align: center;">Randevu Al</a>
                </div>
                @await Component.InvokeAsync("_TourDetailLast3TourComponentPartial")
            </div>
        </div>
    </div>

</div>
