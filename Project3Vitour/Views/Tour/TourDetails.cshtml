                        <i class="icon-8"></i>
                    </a>
                </li>
                <li>
                    <a href="#">
                        <i class="icon-6"></i>
                    </a>
                </li>
            </ul>

        </div>
    </div>

    <!-- Javascript -->
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var tabButtons = Array.from(document.querySelectorAll('#pills-tab [data-bs-toggle="pill"]'));
            var tabPanes = Array.from(document.querySelectorAll('#pills-tabContent > .tab-pane'));

            if (!tabButtons.length || !tabPanes.length) {
                return;
            }

            function activateTab(targetSelector) {
                tabButtons.forEach(function (button) {
                    var isActive = button.getAttribute('data-bs-target') === targetSelector;
                    button.classList.toggle('active', isActive);
                    button.setAttribute('aria-selected', isActive ? 'true' : 'false');
                });

                tabPanes.forEach(function (pane) {
                    var isActive = ('#' + pane.id) === targetSelector;
                    pane.classList.toggle('show', isActive);
                    pane.classList.toggle('active', isActive);
                });
            }

            tabButtons.forEach(function (button) {
                button.addEventListener('click', function () {
                    var targetSelector = button.getAttribute('data-bs-target');
                    if (targetSelector) {
                        activateTab(targetSelector);
                    }
                });
            });

            var activeButton = tabButtons.find(function (button) {
                return button.classList.contains('active');
            });

            activateTab(activeButton ? activeButton.getAttribute('data-bs-target') : '#pills-information');
        });
    </script>
    @await Component.InvokeAsync("_TourScriptsComponentPartial")

</body>

</html>




