
@{
    Layout = null;
}


<!DOCTYPE html>

<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en-US" lang="en-US">

@await Component.InvokeAsync("_TourHeadComponentPartial")

<body class="body header-fixed ">

    <div class="preload preload-container">
        <svg class="pl" width="240" height="240" viewBox="0 0 240 240">
            <circle class="pl__ring pl__ring--a" cx="120" cy="120" r="105" fill="none" stroke="#000" stroke-width="20"
                    stroke-dasharray="0 660" stroke-dashoffset="-330" stroke-linecap="round"></circle>
            <circle class="pl__ring pl__ring--b" cx="120" cy="120" r="35" fill="none" stroke="#000" stroke-width="20"
                    stroke-dasharray="0 220" stroke-dashoffset="-110" stroke-linecap="round"></circle>
            <circle class="pl__ring pl__ring--c" cx="85" cy="120" r="70" fill="none" stroke="#000" stroke-width="20"
                    stroke-dasharray="0 440" stroke-linecap="round"></circle>
            <circle class="pl__ring pl__ring--d" cx="155" cy="120" r="70" fill="none" stroke="#000" stroke-width="20"
                    stroke-dasharray="0 440" stroke-linecap="round"></circle>
        </svg>
    </div>

    <!-- /preload -->

    <div id="wrapper">
        <div id="pagee" class="clearfix">

            @await Component.InvokeAsync("_TourHeaderComponentPartial")
            
            <main id="main">                <style>
                    #tourlist-hero {
                        position: relative;
                        min-height: 360px;
                        overflow: hidden;
                        background-color: #1f2937;
                        background-image: url('https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&w=2400&q=80');
                        background-position: center;
                        background-repeat: no-repeat;
                        background-size: cover;
                    }
                    #tourlist-hero > img {
                        position: absolute;
                        inset: 0;
                        width: 100%;
                        height: 100%;
                        object-fit: cover;
                        z-index: 0;
                        display: block;
                    }
                    #tourlist-hero .tf-container {
                        position: relative;
                        z-index: 2;
                        padding: 137px 0 135px;
                    }
                </style><section id="tourlist-hero">
                    <img src="https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&w=2400&q=80" alt="TourList Background">
                    <div class="tf-container">
                        <div class="row">
                            <div class="col-lg-12 center z-index1">
                                <h1 class="title" style="color:#fff;"> Güncel Turlar</h1>
                                <ul class="breadcumb-list flex-five">
                                    <li><a href="index.html">Ana Sayfa</a></li>
                                    <li><span style="color:#fff;">Tur Paketleri</span></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </section>

                @await Component.InvokeAsync("_TourWidgetSelectComponentPartial")
                
                @await Component.InvokeAsync("_AllTourListComponentPartial")

               
                <!-- Widget archieve tour -->
               
                <!-- Widget archieve tour -->

            </main>

            @await Component.InvokeAsync("_TourFooterComponentPartial")

            <!-- Bottom -->
        </div>
        <!-- /#page -->
    </div>

    <!-- Modal Popup Bid -->

    <a id="scroll-top" class="button-go"></a>


    <!-- Javascript -->
    @await Component.InvokeAsync("_TourScriptsComponentPartial")

</body>

</html>