/* ==============================================
   DİL MOTORU
============================================== */
function applyLanguage(lang) {
  var t = i18n[lang];
  if (!t) return;
  currentLang = lang;
  document.documentElement.lang = lang;
  document.title = t.pageTitle;

  /* data-i18n → textContent */
  var els = document.querySelectorAll("[data-i18n]");
  for (var i=0; i<els.length; i++) {
    var key = els[i].getAttribute("data-i18n");
    if (t[key] !== undefined) els[i].textContent = t[key];
  }

  /* data-i18n-html → innerHTML */
  var hels = document.querySelectorAll("[data-i18n-html]");
  for (var j=0; j<hels.length; j++) {
    var hk = hels[j].getAttribute("data-i18n-html");
    if (t[hk] !== undefined) hels[j].innerHTML = t[hk];
  }

  /* data-i18n-err → error mesajları */
  var eels = document.querySelectorAll("[data-i18n-err]");
  for (var k=0; k<eels.length; k++) {
    var ek = eels[k].getAttribute("data-i18n-err");
    if (t[ek] !== undefined) eels[k].textContent = "\u26A0 " + t[ek];
  }

  /* Placeholders */
  var ph = { nameSurname:t.phName, phone:t.phPhone, city:t.phCity };
  Object.keys(ph).forEach(function(id){
    var el = document.getElementById(id);
    if (el) el.placeholder = ph[id];
  });

  /* Select placeholders */
  var oc = document.getElementById("optCountryEl");
  if (oc) oc.textContent = t.optCountry;
  var ot = document.getElementById("optTourEl");
  if (ot) ot.textContent = t.optTour;

  /* Kişi sayısı özet */
  var cnt = parseInt(personCountEl.value, 10) || 1;
  sumPersons.textContent = t.persons(cnt);

  /* Kontenjan metnini aktif tur için yenile */
  if (tourIdHidden.value) updateQuota(tourIdHidden.value);

  /* Aktif dil butonu */
  var btns = document.querySelectorAll(".lang-btn");
  for (var b=0; b<btns.length; b++)
    btns[b].classList.toggle("active", btns[b].getAttribute("data-lang") === lang);

  localStorage.setItem("rvz_lang", lang);
}

var langBtns = document.querySelectorAll(".lang-btn");
for (var lb=0; lb<langBtns.length; lb++) {
  langBtns[lb].addEventListener("click", function(){
    applyLanguage(this.getAttribute("data-lang"));
  });
}

/* ==============================================
   ÖZET & FİYAT HESABI
============================================== */
function updateSummary() {
  var count = Math.max(1, parseInt(personCountEl.value, 10) || 1);
  var total = count * PER_PERSON_PRICE;
  totalPriceEl.value = PER_PERSON_PRICE > 0 ? formatCurrency(total) : "\u2014";
  sumPersons.textContent = i18n[currentLang].persons(count);
  sumTotal.textContent = PER_PERSON_PRICE > 0 ? formatCurrency(total) : "\u2014";
}

function updateDateSummary() {
  sumDate.textContent = reservationDateEl.value ? formatDate(reservationDateEl.value) : "\u2014";
}

/* ==============================================
   TUR SEÇİMİ
============================================== */
function onTourChange() {
  var val  = tourSelectEl.value;
  var tour = TOURS[val];
  if (!tour) { tourInfoBox.style.display = "none"; return; }

  PER_PERSON_PRICE   = tour.price;
  tourIdHidden.value = val;

  /* Bilgi kartı */
  var optText = tourSelectEl.options[tourSelectEl.selectedIndex].textContent;
  tsiIcon.innerHTML  = tour.icon;
  tsiName.textContent = optText;
  tsiPrice.textContent = formatCurrency(tour.price) + " / " + i18n[currentLang].perPerson;
  tourInfoBox.style.display = "flex";
  unitPriceEl.value  = formatCurrency(tour.price);

  /* Özet kart */
  if (sumTourName) sumTourName.textContent = optText;
  if (sumTourMeta) sumTourMeta.innerHTML = tour.icon + "&nbsp; " + formatCurrency(tour.price) + " / " + i18n[currentLang].perPerson;
  if (sumUnitDisp) sumUnitDisp.textContent = formatCurrency(tour.price);

  updateSummary();
}

tourSelectEl.addEventListener("change", function(){
  onTourChange();
  updateQuota(tourSelectEl.value);
  var grp = tourSelectEl.closest(".form-group");
  if (grp) grp.classList.remove("has-error");
});

personCountEl.addEventListener("input", function(){
  updateSummary();
  if (tourIdHidden.value) updateQuota(tourIdHidden.value);
});

reservationDateEl.addEventListener("change", updateDateSummary);

/* ==============================================
   KONTENJAN KONTROLÜ
============================================== */
function updateQuota(tourId) {
  var t    = i18n[currentLang];
  var tour = tourId ? TOURS[tourId] : null;

  if (!tour) {
    quotaWrap.style.display   = "none";
    quotaBar.className        = "quota-bar";
    sumQuotaRow.style.display = "none";
    return;
  }

  var available = tour.capacity - tour.booked;
  var requested = Math.max(1, parseInt(personCountEl.value, 10) || 1);
  var pct       = Math.round((tour.booked / tour.capacity) * 100);
  var status    = available === 0 ? "full" : (available <= 3 ? "warn" : "ok");

  quotaWrap.style.display = "block";
  quotaBar.className      = "quota-bar show " + status;

  var barColor = status === "full" ? "#ff6b7a" : (status === "warn" ? "#fbbf24" : "var(--accent)");
  quotaProgressBar.style.width      = pct + "%";
  quotaProgressBar.style.background = barColor;

  if (status === "full") {
    quotaIcon.textContent  = "\u274C";
    quotaText.textContent  = t.quotaFull;
    quotaCount.textContent = "0 / " + tour.capacity;
  } else if (status === "warn") {
    quotaIcon.textContent  = "\u26A0\uFE0F";
    quotaText.textContent  = t.quotaWarn.replace("{n}", available);
    quotaCount.textContent = available + " / " + tour.capacity;
  } else {
    quotaIcon.textContent  = "\u2705";
    quotaText.textContent  = t.quotaOk.replace("{n}", available);
    quotaCount.textContent = available + " / " + tour.capacity;
  }

  /* Kişi sayısı kontenjanı aşıyor mu? */
  if (status !== "full" && requested > available) {
    quotaBar.className     = "quota-bar show full";
    quotaIcon.textContent  = "\u274C";
    quotaText.textContent  = t.quotaExceed.replace("{r}", requested).replace("{a}", available);
    quotaProgressBar.style.background = "#ff6b7a";
    status = "full"; /* pill için */
  }

  /* Özet kart pill */
  sumQuotaRow.style.display = "flex";
  sumQuotaPill.className    = "quota-pill " + status;
  if (status === "full") {
    sumQuotaPill.textContent = t.quotaPillFull + " \u274C";
  } else if (status === "warn") {
    sumQuotaPill.textContent = available + " " + t.quotaPillLeft + " \u26A0\uFE0F";
  } else {
    sumQuotaPill.textContent = available + " " + t.quotaPillAvail + " \u2705";
  }
}

function isQuotaBlocked() {
  var id = tourIdHidden.value;
  if (!id || !TOURS[id]) return false;
  var available = TOURS[id].capacity - TOURS[id].booked;
  var requested = Math.max(1, parseInt(personCountEl.value, 10) || 1);
  return available === 0 || requested > available;
}

/* ==============================================
   VALİDASYON
============================================== */
var validators = {
  tourSelect:      function(v){ return v !== "" && TOURS[v] !== undefined; },
  nameSurname:     function(v){ return v.trim().length >= 3 && v.trim().indexOf(" ") !== -1; },
  phone:           function(v){ return /^[+\d][\d\s\-()\+]{7,16}$/.test(v.trim()); },
  email:           function(v){ return /^[^\s\x40]+\x40[^\s\x40]+\.[^\s\x40]{2,}$/.test(v.trim()); },
  city:            function(v){ return v.trim().length >= 2; },
  country:         function(v){ return v !== "" && v !== null; },
  reservationDate: function(v){
    if (!v) return false;
    var ch = new Date(v + "T00:00:00");
    var td = new Date(); td.setHours(0,0,0,0);
    return ch >= td;
  },
  personCount: function(v){ return parseInt(v, 10) >= 1; }
};

function validateField(field) {
  var name  = field.name;
  var value = field.value;
  var group = field.closest(".form-group");
  var span  = group ? group.querySelector("[data-i18n-err]") : null;
  if (!validators[name]) return true;
  var ok = validators[name](value);
  if (ok) {
    group.classList.remove("has-error");
  } else {
    group.classList.add("has-error");
    if (span) {
      var k = span.getAttribute("data-i18n-err");
      var m = i18n[currentLang][k];
      if (m) span.textContent = "\u26A0 " + m;
    }
  }
  return ok;
}

var allFields = form.querySelectorAll("input:not([type=hidden]):not([readonly]), select");
for (var af=0; af<allFields.length; af++) {
  allFields[af].addEventListener("blur", (function(el){ return function(){ validateField(el); }; })(allFields[af]));
  allFields[af].addEventListener("input", (function(el){ return function(){
    if (el.closest(".form-group").classList.contains("has-error")) validateField(el);
  }; })(allFields[af]));
}

/* ==============================================
   TELEFON MASK
============================================== */
document.getElementById("phone").addEventListener("input", function(){
  this.value = this.value.replace(/[^\d\s+\-()\+]/g, "");
});

/* ==============================================
   FORM SUBMIT
============================================== */
form.addEventListener("submit", async function(e){
  e.preventDefault();

  /* Validasyon */
  var fields = form.querySelectorAll("input:not([type=hidden]):not([readonly]), select");
  var valid  = true;
  for (var fi=0; fi<fields.length; fi++) {
    if (!validateField(fields[fi])) valid = false;
  }
  if (!valid) {
    var fe = form.querySelector(".has-error input, .has-error select");
    if (fe){ fe.scrollIntoView({behavior:"smooth",block:"center"}); fe.focus(); }
    return;
  }

  /* Kontenjan kontrolü */
  if (isQuotaBlocked()) {
    updateQuota(tourIdHidden.value);
    quotaWrap.scrollIntoView({behavior:"smooth",block:"center"});
    var qb = document.getElementById("quotaBar");
    qb.style.animation = "none";
    setTimeout(function(){ qb.style.animation = "shake .4s ease"; }, 10);
    return;
  }

  submitBtn.classList.add("loading");
  submitBtn.disabled = true;

  var count = parseInt(personCountEl.value, 10);
  var code  = reservationCodeEl.value;

  var payload = {
    nameSurname:     document.getElementById("nameSurname").value.trim(),
    phone:           document.getElementById("phone").value.trim(),
    email:           document.getElementById("email").value.trim(),
    city:            document.getElementById("city").value.trim(),
    country:         document.getElementById("country").value,
    reservationDate: new Date(reservationDateEl.value + "T00:00:00").toISOString(),
    personCount:     count,
    totalPrice:      count * PER_PERSON_PRICE,
    reservationCode: code,
    tourId:          tourIdHidden.value
  };

  console.log("Payload:", payload);

  try {
    var response = await fetch(API_ENDPOINT, {
      method:"POST",
      headers:{"Content-Type":"application/json"},
      body:JSON.stringify(payload)
    });

    var result = await response.json();

    if (!response.ok) {
      throw new Error(result && result.message ? result.message : "Rezervasyon kaydedilemedi.");
    }

    submitBtn.classList.remove("loading");
    submitBtn.disabled = false;
    successRef.textContent = result.reservationCode || code;
    successOverlay.classList.add("show");

    if (result.emailSent === false) {
      alert("Rezervasyon kaydedildi ancak e-posta gonderilemedi: " + (result.emailError || "Bilinmeyen hata"));
    }
  } catch(err) {
    submitBtn.classList.remove("loading");
    submitBtn.disabled = false;
    alert(err && err.message ? err.message : "Rezervasyon sirasinda bir hata olustu.");
  }
});

/* ==============================================
   MODAL
============================================== */
document.getElementById("btnClose").addEventListener("click", function(){ successOverlay.classList.remove("show"); });
document.getElementById("btnNew").addEventListener("click", function(){ successOverlay.classList.remove("show"); resetForm(); });
successOverlay.addEventListener("click", function(e){ if(e.target === successOverlay) successOverlay.classList.remove("show"); });
document.addEventListener("keydown", function(e){ if(e.key === "Escape") successOverlay.classList.remove("show"); });

/* ==============================================
   FORM SIFIRLA
============================================== */
function resetForm() {
  form.reset();
  var eg = form.querySelectorAll(".has-error");
  for (var i=0; i<eg.length; i++) eg[i].classList.remove("has-error");

  reservationCodeEl.value  = generateCode();
  tourIdHidden.value       = "";
  PER_PERSON_PRICE         = 0;

  tourInfoBox.style.display  = "none";
  quotaWrap.style.display    = "none";
  quotaBar.className         = "quota-bar";
  sumQuotaRow.style.display  = "none";

  unitPriceEl.value = "\u2014";
  totalPriceEl.value = "\u2014";

  sumCode.textContent    = reservationCodeEl.value;
  sumDate.textContent    = "\u2014";
  sumTotal.textContent   = "\u2014";
  sumUnitDisp.textContent = "\u2014";

  if (sumTourName) { sumTourName.textContent = i18n[currentLang].tourName; }
  if (sumTourMeta) { sumTourMeta.textContent = i18n[currentLang].tourMeta; }

  updateSummary();
  window.scrollTo({top:0, behavior:"smooth"});
}

/* ==============================================
   BAŞLANGIÇ
============================================== */
var todayISO = new Date().toISOString().split("T")[0];
reservationDateEl.setAttribute("min", todayISO);
reservationCodeEl.value = generateCode();
sumCode.textContent     = reservationCodeEl.value;

applyLanguage(currentLang);
</script>
</body>
