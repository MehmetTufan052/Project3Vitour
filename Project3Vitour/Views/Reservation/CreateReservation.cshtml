@{
    Layout = null;
}

@model List<Project3Vitour.Dtos.TourDtos.ResultTourDto>
@using System.Text.Json

<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Rezervasyon — Premium Tur Deneyimi</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,700;1,500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg-grad-1:#071a0f; --bg-grad-2:#0a2318; --bg-grad-3:#071510;
      --accent:#2ecc71; --accent-light:#4ade80; --accent-dim:rgba(46,204,113,.18);
      --glass-bg:rgba(46,204,113,.045); --glass-border:rgba(46,204,113,.15);
      --glass-shadow:0 24px 64px rgba(0,0,0,.50),0 2px 0 rgba(46,204,113,.08) inset;
      --text-primary:#e8f5ee; --text-secondary:#7aab8a; --text-muted:rgba(232,245,238,.35);
      --error:#ff6b7a; --success:#4ade80;
      --radius-lg:22px; --radius-md:14px; --radius-sm:9px;
      --font-display:'Playfair Display',serif; --font-body:'DM Sans',sans-serif;
      --transition:.25s cubic-bezier(.4,0,.2,1);
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{font-family:var(--font-body);background:var(--bg-grad-1);color:var(--text-primary);min-height:100vh;overflow-x:hidden}

    /* ── BACKGROUND ── */
    .bg-canvas{position:fixed;inset:0;z-index:0;background:
      radial-gradient(ellipse 80% 60% at 15% 10%,rgba(22,163,74,.25) 0%,transparent 60%),
      radial-gradient(ellipse 60% 50% at 85% 80%,rgba(6,78,59,.35) 0%,transparent 55%),
      radial-gradient(ellipse 70% 70% at 50% 50%,rgba(74,222,128,.08) 0%,transparent 65%),
      linear-gradient(135deg,var(--bg-grad-1) 0%,var(--bg-grad-2) 50%,var(--bg-grad-3) 100%)}
    .orb{position:fixed;border-radius:50%;filter:blur(90px);opacity:.35;animation:drift 18s ease-in-out infinite alternate;pointer-events:none;z-index:0}
    .orb-1{width:520px;height:520px;background:#16a34a;top:-180px;left:-140px;animation-duration:22s}
    .orb-2{width:420px;height:420px;background:#065f46;bottom:-120px;right:-100px;animation-duration:18s;animation-delay:-8s}
    .orb-3{width:300px;height:300px;background:#4ade80;top:40%;left:55%;animation-duration:25s;animation-delay:-4s;opacity:.18}
    @@keyframes drift{from{transform:translate(0,0) scale(1)}to{transform:translate(40px,30px) scale(1.08)}}

    /* ── LANGUAGE SWITCHER ── */
    .lang-bar{position:fixed;top:20px;right:24px;z-index:50;display:flex;gap:6px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);border-radius:100px;padding:5px 8px;backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px)}
    .lang-btn{padding:5px 13px;border:none;border-radius:100px;background:transparent;color:var(--text-secondary);font-family:var(--font-body);font-size:.75rem;font-weight:600;letter-spacing:.06em;cursor:pointer;transition:background var(--transition),color var(--transition)}
    .lang-btn:hover{color:var(--text-primary)}
    .lang-btn.active{background:linear-gradient(135deg,var(--accent-light),var(--accent));color:#052e16}

    /* ── PAGE ── */
    .page-wrapper{position:relative;z-index:1;min-height:100vh;display:flex;flex-direction:column;align-items:center;padding:60px 20px 80px}

    /* ── HERO ── */
    .hero{text-align:center;margin-bottom:52px;animation:fadeDown .7s var(--transition) both}
    .hero-tag{display:inline-flex;align-items:center;gap:8px;background:var(--accent-dim);border:1px solid rgba(46,204,113,.30);border-radius:100px;padding:6px 18px;font-size:.72rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--accent-light);margin-bottom:22px}
    .hero-tag::before{content:'✦';font-size:.65rem}
    .hero h1{font-family:var(--font-display);font-size:clamp(2.2rem,5vw,3.4rem);font-weight:700;line-height:1.15;background:linear-gradient(135deg,#e8f5ee 30%,var(--accent) 80%,var(--accent-light) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:14px}
    .hero p{font-size:1.05rem;color:var(--text-secondary);max-width:480px;margin:0 auto;line-height:1.65;font-weight:300}

    /* ── GRID ── */
    .main-grid{display:grid;grid-template-columns:1fr 340px;gap:28px;width:100%;max-width:1060px;align-items:start}

    /* ── GLASS CARD ── */
    .glass-card{background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:var(--radius-lg);backdrop-filter:blur(28px) saturate(1.6);-webkit-backdrop-filter:blur(28px) saturate(1.6);box-shadow:var(--glass-shadow);padding:44px 42px;animation:fadeUp .65s var(--transition) .15s both;transition:border-color var(--transition)}
    .glass-card:hover{border-color:rgba(255,255,255,.16)}
    .card-title{font-family:var(--font-display);font-size:1.35rem;font-weight:500;color:var(--text-primary);margin-bottom:6px}
    .card-subtitle{font-size:.82rem;color:var(--text-secondary);margin-bottom:32px;font-weight:300}

    /* ── FORM GRID ── */
    .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px 22px}
    .form-grid .span-2{grid-column:1/-1}

    /* ── FORM GROUP ── */
    .form-group{display:flex;flex-direction:column;gap:7px}
    .form-group label{font-size:.72rem;font-weight:600;letter-spacing:.09em;text-transform:uppercase;color:var(--text-secondary);transition:color var(--transition)}
    .form-group:focus-within label{color:var(--accent-light)}
    .form-group input,.form-group select{background:rgba(255,255,255,.055);border:1px solid rgba(255,255,255,.10);border-radius:var(--radius-sm);padding:13px 16px;color:var(--text-primary);font-family:var(--font-body);font-size:.93rem;font-weight:400;outline:none;transition:border-color var(--transition),background var(--transition),box-shadow var(--transition);appearance:none;-webkit-appearance:none}
    .form-group select{cursor:pointer}
    .form-group select option{background:#0d2010;color:var(--text-primary)}
    .form-group input::placeholder{color:rgba(122,171,138,.45)}
    .form-group input:hover,.form-group select:hover{background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.18)}
    .form-group input:focus,.form-group select:focus{border-color:var(--accent);background:rgba(46,204,113,.07);box-shadow:0 0 0 3px rgba(46,204,113,.15)}
    .form-group input[readonly]{background:rgba(255,255,255,.03);border-color:rgba(255,255,255,.06);color:var(--accent-light);font-weight:500;cursor:default}

    /* ── ERROR ── */
    .form-group.has-error input,.form-group.has-error select{border-color:var(--error);box-shadow:0 0 0 3px rgba(255,107,122,.15)}
    .error-msg{font-size:.75rem;color:var(--error);display:none;align-items:center;gap:5px}
    .form-group.has-error .error-msg{display:flex}

    /* ── DIVIDER ── */
    .form-divider{grid-column:1/-1;display:flex;align-items:center;gap:14px;margin:6px 0}
    .form-divider span{font-size:.68rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--text-muted);white-space:nowrap}
    .form-divider::before,.form-divider::after{content:'';flex:1;height:1px;background:var(--glass-border)}

    /* ── TOUR SELECT INFO ── */
    .tour-select-info{display:flex;align-items:center;gap:14px;padding:14px 16px;background:rgba(46,204,113,.07);border:1px solid rgba(46,204,113,.22);border-radius:var(--radius-sm)}
    .tsi-icon{width:42px;height:42px;border-radius:10px;background:linear-gradient(135deg,#16a34a,#065f46);display:grid;place-items:center;font-size:1.25rem;flex-shrink:0}
    .tsi-body .tsi-name{font-size:.9rem;font-weight:500;color:var(--text-primary)}
    .tsi-body .tsi-price{font-size:.8rem;color:var(--accent-light);font-weight:600;margin-top:3px}

    /* ── KONTENJAN ── */
    .quota-bar{margin-top:10px;padding:12px 14px;border-radius:var(--radius-sm);display:none;align-items:center;gap:10px;font-size:.82rem;font-weight:500}
    .quota-bar.show{display:flex}
    .quota-bar.ok  {background:rgba(46,204,113,.10);border:1px solid rgba(46,204,113,.25);color:var(--accent-light)}
    .quota-bar.warn{background:rgba(251,191,36,.10);border:1px solid rgba(251,191,36,.30);color:#fbbf24}
    .quota-bar.full{background:rgba(255,107,122,.10);border:1px solid rgba(255,107,122,.30);color:var(--error)}
    .quota-bar .qb-icon{font-size:1rem;flex-shrink:0}
    .quota-bar .qb-text{flex:1}
    .quota-bar .qb-count{font-family:'Courier New',monospace;font-weight:700;font-size:.85rem;margin-left:auto;opacity:.85}
    .quota-progress-wrap{margin-top:8px;height:5px;background:rgba(255,255,255,.08);border-radius:100px;overflow:hidden}
    .quota-progress-bar{height:100%;border-radius:100px;transition:width .5s cubic-bezier(.4,0,.2,1),background .3s}

    /* ── ÖZET KART KONTENJAN ── */
    .quota-summary-row{display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid rgba(255,255,255,.06)}
    .quota-pill{display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:100px;font-size:.72rem;font-weight:600}
    .quota-pill.ok  {background:rgba(46,204,113,.15);color:var(--accent-light)}
    .quota-pill.warn{background:rgba(251,191,36,.15);color:#fbbf24}
    .quota-pill.full{background:rgba(255,107,122,.15);color:var(--error)}

    /* ── SUBMIT BUTTON ── */
    .btn-submit{grid-column:1/-1;margin-top:10px;position:relative;padding:17px 28px;border:none;border-radius:var(--radius-md);cursor:pointer;font-family:var(--font-body);font-size:1rem;font-weight:600;letter-spacing:.04em;color:#052e16;background:linear-gradient(135deg,var(--accent-light) 0%,var(--accent) 60%,#1a7a42 100%);box-shadow:0 8px 32px rgba(46,204,113,.35),0 1px 0 rgba(255,255,255,.25) inset;overflow:hidden;transition:transform var(--transition),box-shadow var(--transition),filter var(--transition)}
    .btn-submit:hover{transform:translateY(-2px);box-shadow:0 14px 42px rgba(46,204,113,.50);filter:brightness(1.07)}
    .btn-submit:active{transform:translateY(0)}
    .btn-submit::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.30) 0%,transparent 60%);pointer-events:none}
    .btn-submit::after{content:'';position:absolute;top:-50%;left:-80%;width:60%;height:200%;background:linear-gradient(100deg,transparent,rgba(255,255,255,.35),transparent);transform:skewX(-20deg);transition:left .6s ease}
    .btn-submit:hover::after{left:140%}
    .btn-submit .btn-label{transition:opacity .2s}
    .btn-submit .spinner{display:none;width:20px;height:20px;border:2px solid rgba(0,0,0,.25);border-top-color:#052e16;border-radius:50%;animation:spin .7s linear infinite;position:absolute;top:50%;left:50%;transform:translate(-50%,-50%)}
    .btn-submit.loading .btn-label{opacity:0}
    .btn-submit.loading .spinner{display:block}

    /* ── SUMMARY CARD ── */
    .summary-card{position:sticky;top:30px;animation:fadeUp .65s var(--transition) .3s both}
    .tour-badge{display:flex;align-items:center;gap:10px;padding:14px;background:rgba(255,255,255,.04);border:1px solid var(--glass-border);border-radius:var(--radius-sm);margin-bottom:22px}
    .tour-badge .tour-img{width:44px;height:44px;border-radius:8px;background:linear-gradient(135deg,#16a34a,#065f46);display:grid;place-items:center;font-size:1.3rem;flex-shrink:0}
    .tour-badge .tour-info .tour-name{font-size:.9rem;font-weight:500;color:var(--text-primary)}
    .tour-badge .tour-info .tour-meta{font-size:.75rem;color:var(--text-secondary);margin-top:2px}
    .summary-rows{display:flex;flex-direction:column;gap:2px}
    .summary-row{display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid rgba(255,255,255,.06)}
    .summary-row:last-child{border-bottom:none}
    .summary-row .s-label{font-size:.8rem;color:var(--text-secondary)}
    .summary-row .s-value{font-size:.9rem;font-weight:500;color:var(--text-primary);text-align:right}
    .summary-row.total .s-label{font-weight:600;font-size:.85rem;color:var(--text-primary)}
    .summary-row.total .s-value{font-family:var(--font-display);font-size:1.25rem;color:var(--accent-light)}
    .summary-code-box{margin-top:20px;padding:14px 16px;background:rgba(46,204,113,.08);border:1px dashed rgba(46,204,113,.30);border-radius:var(--radius-sm);text-align:center}
    .summary-code-box .code-label{font-size:.68rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--text-secondary);margin-bottom:6px}
    .summary-code-box .code-value{font-family:'Courier New',monospace;font-size:1.05rem;font-weight:700;color:var(--accent-light);letter-spacing:.15em}

    /* ── SUCCESS OVERLAY ── */
    .success-overlay{display:none;position:fixed;inset:0;z-index:100;background:rgba(0,0,0,.65);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);place-items:center}
    .success-overlay.show{display:grid}
    .success-modal{background:rgba(5,20,10,.95);border:1px solid rgba(46,204,113,.30);border-radius:var(--radius-lg);padding:52px 44px;max-width:460px;width:90%;text-align:center;box-shadow:0 32px 80px rgba(0,0,0,.7),0 0 0 1px rgba(46,204,113,.12);animation:popIn .45s cubic-bezier(.34,1.56,.64,1) both}
    .success-icon{width:72px;height:72px;background:rgba(46,204,113,.12);border:2px solid rgba(46,204,113,.4);border-radius:50%;display:grid;place-items:center;margin:0 auto 22px;font-size:2rem;animation:pulse 2s ease infinite}
    .success-modal h2{font-family:var(--font-display);font-size:1.75rem;margin-bottom:10px;color:var(--success)}
    .success-modal p{font-size:.95rem;color:var(--text-secondary);line-height:1.6;margin-bottom:28px}
    #success-ref{font-family:'Courier New',monospace;color:var(--accent-light);font-weight:700}
    .success-actions{display:flex;gap:12px;justify-content:center}
    .btn-close-success{padding:12px 28px;border:1px solid rgba(255,255,255,.14);background:rgba(255,255,255,.06);border-radius:var(--radius-md);color:var(--text-primary);font-family:var(--font-body);font-size:.9rem;cursor:pointer;transition:background var(--transition)}
    .btn-close-success:hover{background:rgba(255,255,255,.12)}
    .btn-new-reservation{padding:12px 28px;background:linear-gradient(135deg,var(--success),#16a34a);border:none;border-radius:var(--radius-md);color:#052e16;font-family:var(--font-body);font-size:.9rem;font-weight:600;cursor:pointer;transition:filter var(--transition),transform var(--transition)}
    .btn-new-reservation:hover{filter:brightness(1.1);transform:translateY(-1px)}

    /* ── FOOTER ── */
    .page-footer{margin-top:52px;text-align:center;font-size:.78rem;color:var(--text-muted);letter-spacing:.04em}
    .page-footer span{color:var(--accent)}

    /* ── ANIMATIONS ── */
    @@keyframes fadeDown{from{opacity:0;transform:translateY(-24px)}to{opacity:1;transform:translateY(0)}}
    @@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
    @@keyframes fadeIn{from{opacity:0}to{opacity:1}}
    @@keyframes popIn{from{opacity:0;transform:scale(.88)}to{opacity:1;transform:scale(1)}}
    @@keyframes spin{to{transform:translate(-50%,-50%) rotate(360deg)}}
    @@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(46,204,113,.3)}50%{box-shadow:0 0 0 14px rgba(46,204,113,0)}}
    @@keyframes shake{0%,100%{transform:translateX(0)}20%{transform:translateX(-6px)}60%{transform:translateX(6px)}}

    /* ── RESPONSIVE ── */
    @@media(max-width:860px){.main-grid{grid-template-columns:1fr}.summary-card{position:static;order:-1}}
    @@media(max-width:600px){.glass-card{padding:28px 22px}.form-grid{grid-template-columns:1fr}.form-grid .span-2{grid-column:auto}.btn-submit{grid-column:auto}.lang-bar{top:12px;right:12px}}

    /* ── SCROLLBAR ── */
    ::-webkit-scrollbar{width:6px}::-webkit-scrollbar-track{background:transparent}
    ::-webkit-scrollbar-thumb{background:rgba(46,204,113,.20);border-radius:3px}
    input[type="date"]::-webkit-calendar-picker-indicator{filter:invert(.6) sepia(1) saturate(3) hue-rotate(90deg);cursor:pointer;opacity:.7}
    input[type="number"]::-webkit-inner-spin-button,input[type="number"]::-webkit-outer-spin-button{opacity:.5}
  </style>
</head>
<body>

<div class="bg-canvas"></div>
<div class="orb orb-1"></div>
<div class="orb orb-2"></div>
<div class="orb orb-3"></div>

<!-- DIL SECİCİ -->
<nav class="lang-bar" aria-label="Language selector">
  <button class="lang-btn active" data-lang="tr">TR</button>
  <button class="lang-btn" data-lang="en">EN</button>
  <button class="lang-btn" data-lang="fr">FR</button>
  <button class="lang-btn" data-lang="es">ES</button>
</nav>

<div class="page-wrapper">

  <!-- HERO -->
  <header class="hero">
    <div class="hero-tag" data-i18n="heroTag"></div>
    <h1 data-i18n-html="heroTitle"></h1>
    <p data-i18n="heroDesc"></p>
  </header>

  <main class="main-grid">

    <!-- FORM KARTI -->
    <section class="glass-card">
      <h2 class="card-title" data-i18n="formTitle"></h2>
      <p class="card-subtitle" data-i18n="formSubtitle"></p>

      <form id="reservationForm" novalidate>
        <input type="hidden" id="reservationCode" name="reservationCode" />
        <input type="hidden" id="tourId"           name="tourId" value="" />

        <div class="form-grid">

          <!-- TUR SECİMİ -->
          <div class="form-divider span-2"><span data-i18n="sectionTourSelect"></span></div>

          <div class="form-group span-2">
            <label for="tourSelect"><span data-i18n="labelTourSelect"></span> <span style="color:var(--error)">*</span></label>
            <select id="tourSelect" name="tourSelect">
              <option value="" disabled selected id="optTourEl"></option>
              @foreach (var tour in Model)
              {
                <option value="@tour.TourId">@tour.Title - @tour.DayCount Gun</option>
              }
            </select>
            <span class="error-msg" data-i18n-err="errTourSelect"></span>
          </div>

          <!-- Tur bilgi kartı -->
          <div class="tour-select-info span-2" id="tourInfoBox" style="display:none;">
            <span class="tsi-icon" id="tsiIcon"></span>
            <div class="tsi-body">
              <div class="tsi-name" id="tsiName"></div>
              <div class="tsi-price" id="tsiPrice"></div>
            </div>
          </div>

          <!-- Kontenjan göstergesi -->
          <div class="span-2" id="quotaWrap" style="display:none;">
            <div class="quota-bar" id="quotaBar">
              <span class="qb-icon" id="quotaIcon"></span>
              <span class="qb-text" id="quotaText"></span>
              <span class="qb-count" id="quotaCount"></span>
            </div>
            <div class="quota-progress-wrap">
              <div class="quota-progress-bar" id="quotaProgressBar" style="width:0%"></div>
            </div>
          </div>

          <!-- KİSİSEL BİLGİLER -->
          <div class="form-divider span-2"><span data-i18n="sectionPersonal"></span></div>

          <div class="form-group span-2">
            <label for="nameSurname"><span data-i18n="labelName"></span> <span style="color:var(--error)">*</span></label>
            <input type="text" id="nameSurname" name="nameSurname" autocomplete="name" />
            <span class="error-msg" data-i18n-err="errName"></span>
          </div>

          <div class="form-group">
            <label for="phone"><span data-i18n="labelPhone"></span> <span style="color:var(--error)">*</span></label>
            <input type="tel" id="phone" name="phone" autocomplete="tel" maxlength="17" />
            <span class="error-msg" data-i18n-err="errPhone"></span>
          </div>

          <div class="form-group">
            <label for="email"><span data-i18n="labelEmail"></span> <span style="color:var(--error)">*</span></label>
            <input type="email" id="email" name="email" placeholder="example@email.com" autocomplete="email" />
            <span class="error-msg" data-i18n-err="errEmail"></span>
          </div>

          <!-- KONUM BİLGİLERİ -->
          <div class="form-divider span-2"><span data-i18n="sectionLocation"></span></div>

          <div class="form-group">
            <label for="city"><span data-i18n="labelCity"></span> <span style="color:var(--error)">*</span></label>
            <input type="text" id="city" name="city" autocomplete="address-level2" />
            <span class="error-msg" data-i18n-err="errCity"></span>
          </div>

          <div class="form-group">
            <label for="country"><span data-i18n="labelCountry"></span> <span style="color:var(--error)">*</span></label>
            <select id="country" name="country" autocomplete="country">
              <option value="" disabled selected id="optCountryEl"></option>
              <option value="TR">Turkiye</option>
              <option value="DE">Germany / Allemagne / Alemania</option>
              <option value="GB">United Kingdom / Royaume-Uni</option>
              <option value="FR">France / Fransa / Francia</option>
              <option value="ES">Spain / Espagne / Espana</option>
              <option value="US">USA / Etats-Unis / EE.UU.</option>
              <option value="AE">UAE / EAU</option>
              <option value="OTHER" data-i18n="optOther">Other</option>
            </select>
            <span class="error-msg" data-i18n-err="errCountry"></span>
          </div>

          <!-- REZERVASYON DETAYLARI -->
          <div class="form-divider span-2"><span data-i18n="sectionTourDetails"></span></div>

          <div class="form-group">
            <label for="reservationDate"><span data-i18n="labelDate"></span> <span style="color:var(--error)">*</span></label>
            <input type="date" id="reservationDate" name="reservationDate" />
