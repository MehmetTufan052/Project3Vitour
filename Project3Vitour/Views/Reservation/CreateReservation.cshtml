/* ==============================================
   TUR VERİLERİ  (capacity=kapasite, booked=dolu)
============================================== */
var tourData = @Html.Raw(JsonSerializer.Serialize(
  Model,
  new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase }
));
var TOURS = {};

function getTourIcon(tour) {
  if (!tour || !tour.title) return "&#127758;";
  var title = tour.title.toLowerCase();
  if (title.indexOf("istanbul") >= 0) return "&#127963;";
  if (title.indexOf("antalya") >= 0) return "&#127958;";
  if (title.indexOf("trabzon") >= 0) return "&#127795;";
  return "&#127956;";
}

for (var ti = 0; ti < tourData.length; ti++) {
  var tourItem = tourData[ti];
  TOURS[tourItem.tourId] = {
    price: tourItem.price,
    icon: getTourIcon(tourItem),
    capacity: tourItem.capacity,
    booked: tourItem.bookedCount,
    days: String(tourItem.dayCount)
  };
}

var PER_PERSON_PRICE = 0;
var API_ENDPOINT     = "@Url.Action("CreateReservation", "Reservation")";
var currentLang      = localStorage.getItem("rvz_lang") || "tr";

/* ==============================================
   YARDIMCI FONKSİYONLAR
============================================== */
function formatCurrency(amount) {
  return new Intl.NumberFormat("tr-TR", {style:"currency", currency:"TRY", minimumFractionDigits:2}).format(amount);
}

function formatDate(value) {
  if (!value) return "\u2014";
  var p = value.split("-");
  return p[2] + "." + p[1] + "." + p[0];
}

function generateCode() {
  var c = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789";
  function seg(n){ var s=""; for(var i=0;i<n;i++) s+=c[Math.floor(Math.random()*c.length)]; return s; }
  return "RVZ-" + seg(4) + "-" + seg(4);
}

