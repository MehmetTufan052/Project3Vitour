/* =========================================
   DİL MOTORU
========================================= */
var currentLang = localStorage.getItem("rvz_lang") || "tr";

function applyLanguage(lang) {
  var t = i18n[lang];
  if (!t) return;
  currentLang = lang;

  document.documentElement.lang = lang;
  document.title = t.pageTitle;

  /* data-i18n: textContent */
  var els = document.querySelectorAll("[data-i18n]");
  for (var i = 0; i < els.length; i++) {
    var key = els[i].getAttribute("data-i18n");
    if (t[key] !== undefined) els[i].textContent = t[key];
  }

  /* data-i18n-html: innerHTML (başlık satır kırmaları için) */
  var htmlEls = document.querySelectorAll("[data-i18n-html]");
  for (var j = 0; j < htmlEls.length; j++) {
    var hkey = htmlEls[j].getAttribute("data-i18n-html");
    if (t[hkey] !== undefined) htmlEls[j].innerHTML = t[hkey];
  }

  /* data-i18n-err: hata mesajları */
  var errEls = document.querySelectorAll("[data-i18n-err]");
  for (var k = 0; k < errEls.length; k++) {
    var ekey = errEls[k].getAttribute("data-i18n-err");
    if (t[ekey] !== undefined) errEls[k].textContent = "\u26A0 " + t[ekey];
  }

  /* Placeholder'lar */
  var inputs = {
    nameSurname:     t.phName,
    phone:           t.phPhone,
    city:            t.phCity
  };
  Object.keys(inputs).forEach(function(id) {
    var el = document.getElementById(id);
    if (el) el.placeholder = inputs[id];
  });

  /* Select ilk option */
  var optEl = document.getElementById("optCountryEl");
  if (optEl) optEl.textContent = t.optCountry;

  /* Tur select ilk option */
  var optTourEl = document.querySelector("#tourSelect option[value='']");
  if (optTourEl) optTourEl.textContent = t.optTour || "Tur seciniz";

  var optionEls = document.querySelectorAll("#tourSelect option[data-i18n-opt]");
  for (var o = 0; o < optionEls.length; o++) {
    var optionKey = optionEls[o].getAttribute("data-i18n-opt");
    if (t[optionKey] !== undefined) optionEls[o].textContent = t[optionKey];
  }

  /* Kişi sayısı özetini güncelle */
  var count = parseInt(document.getElementById("personCount").value, 10) || 1;
  document.getElementById("sum-persons").textContent = t.persons(count);

  if (tourSelectEl && tourSelectEl.value) {
    onTourChange();
  }

  /* Aktif buton */
  var btns = document.querySelectorAll(".lang-btn");
  for (var b = 0; b < btns.length; b++) {
    btns[b].classList.toggle("active", btns[b].getAttribute("data-lang") === lang);
  }

  localStorage.setItem("rvz_lang", lang);
}

/* Dil butonları */
var langBtns = document.querySelectorAll(".lang-btn");
for (var lb = 0; lb < langBtns.length; lb++) {
  langBtns[lb].addEventListener("click", function() {
    applyLanguage(this.getAttribute("data-lang"));
  });
}

/* =========================================
   SABİTLER & YARDIMCILAR
========================================= */
/* =========================================
   TUR VERİLERİ
========================================= */
var TOURS = {
  "TOUR-2025-KAPADOKYA": { price:1250, icon:"&#127956;" },
  "TOUR-2025-PAMUKKALE": { price:980,  icon:"&#9832;" },
  "TOUR-2025-ANTALYA":   { price:1500, icon:"&#127958;" },
  "TOUR-2025-ISTANBUL":  { price:750,  icon:"&#127963;" },
  "TOUR-2025-TRABZON":   { price:1100, icon:"&#127795;" },
  "TOUR-2025-NEMRUT":    { price:1350, icon:"&#127956;" }
};

var PER_PERSON_PRICE = 1250; /* Seçime göre güncellenir */
var API_ENDPOINT     = "@Url.Action("CreateReservation", "Reservation")";

function formatCurrency(amount) {
  return new Intl.NumberFormat("tr-TR", { style: "currency", currency: "TRY", minimumFractionDigits: 2 }).format(amount);
}

function formatDate(value) {
  if (!value) return "\u2014";
  var parts = value.split("-");
  return parts[2] + "." + parts[1] + "." + parts[0];
}

function generateId() {
  if (typeof crypto !== "undefined" && crypto.randomUUID) return crypto.randomUUID();
  return Math.random().toString(36).slice(2).toUpperCase();
}

function generateCode() {
  var chars = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789";
  function seg(n) {
    var s = "";
    for (var i = 0; i < n; i++) s += chars[Math.floor(Math.random() * chars.length)];
    return s;
  }
  return "RVZ-" + seg(4) + "-" + seg(4);
}

/* =========================================
   DOM
========================================= */
var form              = document.getElementById("reservationForm");
var personCountEl     = document.getElementById("personCount");
var totalPriceEl      = document.getElementById("totalPrice");
var reservationDateEl = document.getElementById("reservationDate");
var reservationIdEl   = document.getElementById("reservationId");
var reservationCodeEl = document.getElementById("reservationCode");
var tourSelectEl      = document.getElementById("tourSelect");
var tourIdHidden      = document.getElementById("tourId");
var tourInfoBox       = document.getElementById("tourInfoBox");
var tsiIcon           = document.getElementById("tsiIcon");
var tsiName           = document.getElementById("tsiName");
var tsiPrice          = document.getElementById("tsiPrice");
var submitBtn         = document.getElementById("submitBtn");
var successOverlay    = document.getElementById("successOverlay");
var successRef        = document.getElementById("success-ref");
var sumDate           = document.getElementById("sum-date");
var sumPersons        = document.getElementById("sum-persons");
var sumTotal          = document.getElementById("sum-total");
var sumCode           = document.getElementById("sum-code");
var sumUnitPrice      = document.getElementById("sum-unit-price");
var sumTourName       = document.getElementById("sum-tour-name");
var sumTourMeta       = document.getElementById("sum-tour-meta");

var todayISO = new Date().toISOString().split("T")[0];
reservationDateEl.setAttribute("min", todayISO);
reservationIdEl.value   = generateId();
reservationCodeEl.value = generateCode();
sumCode.textContent     = reservationCodeEl.value;

function updateSummary() {
  var count = Math.max(1, parseInt(personCountEl.value, 10) || 1);
  var total = count * PER_PERSON_PRICE;
  document.getElementById("unitPrice").value = formatCurrency(PER_PERSON_PRICE);
  totalPriceEl.value     = formatCurrency(total);
  sumPersons.textContent = i18n[currentLang].persons(count);
  if (sumUnitPrice) sumUnitPrice.textContent = formatCurrency(PER_PERSON_PRICE);
  sumTotal.textContent   = formatCurrency(total);
}

function updateDateSummary() {
  sumDate.textContent = reservationDateEl.value ? formatDate(reservationDateEl.value) : "\u2014";
}

/* Tur seçimi değişince */
function onTourChange() {
  var val = tourSelectEl.value;
  var tour = TOURS[val];
  if (!tour) { tourInfoBox.style.display = "none"; return; }

  /* Fiyatı güncelle */
  PER_PERSON_PRICE = tour.price;
  tourIdHidden.value = val;

  /* Bilgi kartı */
  var selOpt = tourSelectEl.options[tourSelectEl.selectedIndex];
  var optText = selOpt ? selOpt.textContent : "";
  tsiIcon.innerHTML = tour.icon;
  tsiName.textContent = optText;
  tsiPrice.textContent = formatCurrency(tour.price);
  tourInfoBox.style.display = "flex";

  /* Özet kart tur adı */
  if (sumTourName) sumTourName.textContent = optText;
  if (sumTourMeta) sumTourMeta.innerHTML = tour.icon + " &nbsp;" + formatCurrency(tour.price);

  /* Fiyatı yeniden hesapla */
  updateSummary();
}

tourSelectEl.addEventListener("change", function() {
  onTourChange();
  /* Validasyon hatasını temizle */
  var grp = tourSelectEl.closest(".form-group");
  if (grp) grp.classList.remove("has-error");
});

personCountEl.addEventListener("input", updateSummary);
reservationDateEl.addEventListener("change", updateDateSummary);
updateSummary();

document.getElementById("phone").addEventListener("input", function() {
  this.value = this.value.replace(/[^\d\s+\-()\+]/g, "");
});

/* =========================================
   VALIDASYONLAR
========================================= */
var validators = {
  tourSelect:      function(v){ return v !== "" && v !== null && TOURS[v] !== undefined; },
  nameSurname:     function(v){ return v.trim().length >= 3 && v.trim().indexOf(" ") !== -1; },
  phone:           function(v){ return /^[+\d][\d\s\-()\+]{7,16}$/.test(v.trim()); },
  email:           function(v){ return /^[^\s@@]+@@[^\s@@]+\.[^\s@@]{2,}$/.test(v.trim()); },
  city:            function(v){ return v.trim().length >= 2; },
  country:         function(v){ return v !== "" && v !== null; },
  reservationDate: function(v){
    if (!v) return false;
    var chosen = new Date(v + "T00:00:00");
    var today  = new Date(); today.setHours(0,0,0,0);
    return chosen >= today;
  },
  personCount: function(v){ return parseInt(v, 10) >= 1; }
};

function validateField(field) {
  var name    = field.name;
  var value   = field.value;
  var group   = field.closest(".form-group");
  var errSpan = group ? group.querySelector("[data-i18n-err]") : null;
  if (!validators[name]) return true;

  var isValid = validators[name](value);
  if (isValid) {
    group.classList.remove("has-error");
  } else {
    group.classList.add("has-error");
    if (errSpan) {
      var key = errSpan.getAttribute("data-i18n-err");
      var msg = i18n[currentLang][key];
      if (msg) errSpan.textContent = "\u26A0 " + msg;
    }
  }
  return isValid;
}

var allInputs = form.querySelectorAll("input:not([type=hidden]):not([readonly]), select");
for (var ai = 0; ai < allInputs.length; ai++) {
  allInputs[ai].addEventListener("blur", (function(el){ return function(){ validateField(el); }; })(allInputs[ai]));
  allInputs[ai].addEventListener("input", (function(el){ return function(){
    if (el.closest(".form-group").classList.contains("has-error")) validateField(el);
  }; })(allInputs[ai]));
}

/* =========================================
   SUBMIT
========================================= */
form.addEventListener("submit", function(e) {
  e.preventDefault();

  var fields = form.querySelectorAll("input:not([type=hidden]):not([readonly]), select");
  var isFormValid = true;
  for (var fi = 0; fi < fields.length; fi++) {
    if (!validateField(fields[fi])) isFormValid = false;
  }

  if (!isFormValid) {
    var firstError = form.querySelector(".has-error input, .has-error select");
    if (firstError) { firstError.scrollIntoView({ behavior: "smooth", block: "center" }); firstError.focus(); }
    return;
  }

  submitBtn.classList.add("loading");
  submitBtn.disabled = true;

  var count = parseInt(personCountEl.value, 10);
  var code  = reservationCodeEl.value;

  var payload = {
    reservationId:   reservationIdEl.value,
    nameSurname:     document.getElementById("nameSurname").value.trim(),
    phone:           document.getElementById("phone").value.trim(),
    email:           document.getElementById("email").value.trim(),
    city:            document.getElementById("city").value.trim(),
    country:         document.getElementById("country").value,
    reservationDate: new Date(reservationDateEl.value + "T00:00:00").toISOString(),
    personCount:     count,
    totalPrice:      count * PER_PERSON_PRICE,
    reservationCode: code,
    tourId:          tourIdHidden.value
  };

  fetch(API_ENDPOINT, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify(payload)
  })
  .then(function(response) {
    return response.json().then(function(data) {
      return { ok: response.ok, data: data };
    });
  })
  .then(function(result) {
    submitBtn.classList.remove("loading");
    submitBtn.disabled = false;

    if (!result.ok || !result.data || result.data.success !== true) {
      var message = result.data && result.data.message ? result.data.message : "Rezervasyon oluşturulamadı.";
      alert(message);
      return;
    }

    reservationCodeEl.value = result.data.reservationCode || code;
    sumCode.textContent = reservationCodeEl.value;
    successRef.textContent = reservationCodeEl.value;
    successOverlay.classList.add("show");
  })
  .catch(function() {
    submitBtn.classList.remove("loading");
    submitBtn.disabled = false;
    alert("Rezervasyon gönderilirken bir hata oluştu. Lütfen tekrar deneyin.");
  });
});

document.getElementById("btnClose").addEventListener("click", function(){ successOverlay.classList.remove("show"); });
document.getElementById("btnNew").addEventListener("click", function(){ successOverlay.classList.remove("show"); resetForm(); });
successOverlay.addEventListener("click", function(e){ if (e.target === successOverlay) successOverlay.classList.remove("show"); });
document.addEventListener("keydown", function(e){ if (e.key === "Escape") successOverlay.classList.remove("show"); });

function resetForm() {
  form.reset();
  var errGroups = form.querySelectorAll(".has-error");
  for (var eg = 0; eg < errGroups.length; eg++) errGroups[eg].classList.remove("has-error");
  reservationIdEl.value   = generateId();
  reservationCodeEl.value = generateCode();
  tourIdHidden.value      = "";
  PER_PERSON_PRICE        = 1250;
  tourInfoBox.style.display = "none";
  if (sumTourName) { sumTourName.setAttribute("data-i18n","tourName"); sumTourName.textContent = i18n[currentLang].tourName; }
  if (sumTourMeta) { sumTourMeta.setAttribute("data-i18n","tourMeta"); sumTourMeta.textContent = i18n[currentLang].tourMeta; }
  sumCode.textContent     = reservationCodeEl.value;
  sumDate.textContent     = "\u2014";
  updateSummary();
  window.scrollTo({ top: 0, behavior: "smooth" });
}

/* =========================================
   BAŞLANGIÇ
========================================= */
applyLanguage(currentLang);
</script>
</body>
</html>
