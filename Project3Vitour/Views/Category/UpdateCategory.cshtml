@model Project3Vitour.Dtos.CategoryDto.UpdateCategoryDto
@{
    ViewData["Title"] = "Update Category";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    /* ══════════════════════════════════════════════════════════
       UPDATE CATEGORY — FULL WIDTH, ENHANCED
    ══════════════════════════════════════════════════════════ */

    .uc-layout {
        display: grid;
        grid-template-columns: 1fr 320px;
        gap: 22px;
        align-items: start;
        /* max-width kaldırıldı */
    }
    @@media (max-width: 1024px) {
        .uc-layout

    {
        grid-template-columns: 1fr;
    }

    }

    /* ── EDIT BANNER ───────────────────────────────────────── */
    .edit-banner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 16px 22px;
        border-radius: 16px;
        margin-bottom: 22px;
        background: linear-gradient(135deg, rgba(99,102,241,.12) 0%, rgba(139,92,246,.08) 50%, rgba(99,102,241,.05) 100%);
        border: 1px solid rgba(99,102,241,.28);
        backdrop-filter: blur(16px);
        box-shadow: 0 4px 24px rgba(99,102,241,.10), inset 0 1px 0 rgba(255,255,255,.12);
        animation: bannerIn .5s cubic-bezier(.4,0,.2,1) both;
        position: relative;
        overflow: hidden;
    }

        .edit-banner::before {
            content: '';
            position: absolute;
            top: -30px;
            right: -30px;
            width: 120px;
            height: 120px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(99,102,241,.18) 0%, transparent 70%);
            pointer-events: none;
        }

        .edit-banner::after {
            content: '';
            position: absolute;
            bottom: -20px;
            left: 60px;
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(139,92,246,.12) 0%, transparent 70%);
            pointer-events: none;
        }
    @@keyframes bannerIn {
        from

    {
        opacity: 0;
        transform: translateY(-10px);
    }

    to {
        opacity: 1;
        transform: none;
    }

    }

    .eb-left {
        display: flex;
        align-items: center;
        gap: 14px;
        z-index: 1;
    }

    .eb-icon {
        width: 44px;
        height: 44px;
        border-radius: 13px;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        color: #fff;
        flex-shrink: 0;
        box-shadow: 0 0 20px rgba(99,102,241,.45), inset 0 1px 0 rgba(255,255,255,.2);
        position: relative;
    }

        .eb-icon::after {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: inherit;
            background: linear-gradient(180deg, rgba(255,255,255,.22) 0%, transparent 60%);
        }

    .eb-texts {
    }

    .eb-title {
        font-size: 14px;
        font-weight: 800;
        color: #3730a3;
        letter-spacing: -.2px;
    }

    .eb-sub {
        font-size: 11px;
        color: #6366f1;
        opacity: .75;
        margin-top: 2px;
    }

    .eb-right {
        display: flex;
        align-items: center;
        gap: 10px;
        z-index: 1;
    }

    .eb-id {
        font-size: 10px;
        font-family: 'DM Mono', monospace;
        color: #6366f1;
        background: rgba(99,102,241,.12);
        padding: 5px 12px;
        border-radius: 8px;
        border: 1px solid rgba(99,102,241,.2);
        letter-spacing: .5px;
        white-space: nowrap;
    }

    .eb-pulse {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: #10b981;
        flex-shrink: 0;
        box-shadow: 0 0 0 0 rgba(16,185,129,.5);
        animation: pulse 2s ease-in-out infinite;
    }
    @@keyframes pulse {
        0%,100%

    {
        box-shadow: 0 0 0 0 rgba(16,185,129,.4);
    }

    50% {
        box-shadow: 0 0 0 7px rgba(16,185,129,0);
    }

    }

    /* ── MAIN CARD ─────────────────────────────────────────── */
    .uc-card {
        background: #fff;
        border: 1px solid rgba(226,232,240,.9);
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 4px 24px rgba(0,0,0,.07), inset 0 1px 0 rgba(255,255,255,.95);
        animation: cardIn .4s .06s cubic-bezier(.4,0,.2,1) both;
    }
    @@keyframes cardIn {
        from

    {
        opacity: 0;
        transform: translateY(14px)
    }

    to {
        opacity: 1;
        transform: none
    }

    }

    .uc-card-head {
        padding: 22px 28px 18px;
        border-bottom: 1px solid #f0f4f8;
        display: flex;
        align-items: center;
        gap: 16px;
        background: linear-gradient(135deg, #fafbff 0%, #f8f7ff 100%);
    }

    .uc-head-icon {
        width: 46px;
        height: 46px;
        border-radius: 13px;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 19px;
        color: #fff;
        flex-shrink: 0;
        box-shadow: 0 0 20px rgba(99,102,241,.35), inset 0 1px 0 rgba(255,255,255,.2);
        position: relative;
    }

        .uc-head-icon::after {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: inherit;
            background: linear-gradient(180deg, rgba(255,255,255,.22) 0%, transparent 60%);
        }

    .uc-head-title {
        font-size: 16px;
        font-weight: 800;
        color: #0f172a;
        letter-spacing: -.4px;
    }

    .uc-head-sub {
        font-size: 12px;
        color: #94a3b8;
        margin-top: 3px;
    }

    .uc-body {
        padding: 28px;
    }

    /* ── HERO PREVIEW ──────────────────────────────────────── */
    .hero-preview {
        border-radius: 16px;
        margin-bottom: 28px;
        background: linear-gradient(135deg, #f0f0ff 0%, #f5f3ff 50%, #ede9fe 100%);
        border: 1px solid #ddd6fe;
        padding: 24px 28px;
        display: flex;
        align-items: center;
        gap: 20px;
        position: relative;
        overflow: hidden;
        transition: all 300ms;
    }

        .hero-preview::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(99,102,241,.05) 0%, transparent 60%, rgba(139,92,246,.05) 100%);
            pointer-events: none;
        }
    /* Floating orbs */
    .hero-orb {
        position: absolute;
        border-radius: 50%;
        pointer-events: none;
        animation: orbFloat 4s ease-in-out infinite;
    }

    .hero-orb-1 {
        width: 60px;
        height: 60px;
        top: -15px;
        right: 40px;
        background: radial-gradient(circle, rgba(99,102,241,.15) 0%, transparent 70%);
        animation-delay: 0s;
    }

    .hero-orb-2 {
        width: 40px;
        height: 40px;
        bottom: -10px;
        right: 120px;
        background: radial-gradient(circle, rgba(139,92,246,.12) 0%, transparent 70%);
        animation-delay: 2s;
    }
    @@keyframes orbFloat {
        0%,100%

    {
        transform: translateY(0) scale(1);
    }

    50% {
        transform: translateY(-8px) scale(1.1);
    }

    }

    .hero-avatar-wrap {
        position: relative;
        flex-shrink: 0;
    }

    .hero-avatar {
        width: 72px;
        height: 72px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 30px;
        font-weight: 900;
        color: #fff;
        position: relative;
        overflow: hidden;
        box-shadow: 0 8px 28px rgba(99,102,241,.4), 0 0 0 4px rgba(255,255,255,.6), inset 0 2px 0 rgba(255,255,255,.25);
        transition: all 350ms cubic-bezier(.34,1.56,.64,1);
        z-index: 1;
    }

        .hero-avatar:hover {
            transform: scale(1.06) rotate(-2deg);
        }

        .hero-avatar::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(255,255,255,.22) 0%, transparent 55%);
        }

    .hero-avatar-ring {
        position: absolute;
        inset: -6px;
        border-radius: 26px;
        border: 2px solid rgba(99,102,241,.2);
        animation: ringRotate 8s linear infinite;
    }
    @@keyframes ringRotate {
        to

    {
        transform: rotate(360deg);
    }

    }

    .hero-info {
        flex: 1;
        z-index: 1;
    }

    .hero-eyebrow {
        font-size: 9px;
        font-weight: 800;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #a5b4fc;
        font-family: 'DM Mono', monospace;
        margin-bottom: 5px;
    }

    .hero-name {
        font-size: 24px;
        font-weight: 900;
        color: #1e1b4b;
        letter-spacing: -.6px;
        line-height: 1.1;
        transition: all 250ms;
    }

        .hero-name.placeholder {
            color: #c4cdd9;
            font-weight: 400;
            font-style: italic;
            font-size: 18px;
        }

    .hero-status {
        margin-top: 8px;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 11px;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: 20px;
    }

        .hero-status.on {
            background: #f0fdf4;
            color: #15803d;
            border: 1px solid #bbf7d0;
        }

        .hero-status.off {
            background: #f8fafc;
            color: #94a3b8;
            border: 1px solid #e2e8f0;
        }

    .hero-status-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
    }

    .hero-status.on .hero-status-dot {
        background: #10b981;
    }

    .hero-status.off .hero-status-dot {
        background: #cbd5e1;
    }

    /* ── FIELDS ────────────────────────────────────────────── */
    .fields-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 20px;
    }

    .fg {
        display: flex;
        flex-direction: column;
        gap: 7px;
    }

    .fl {
        font-size: 10.5px;
        font-weight: 800;
        color: #475569;
        letter-spacing: .7px;
        text-transform: uppercase;
        display: flex;
        align-items: center;
        gap: 7px;
    }

        .fl i {
            color: #a5b4fc;
            font-size: 11px;
            width: 14px;
            text-align: center;
        }

        .fl .req {
            color: #f43f5e;
            font-size: 13px;
            text-transform: none;
            letter-spacing: 0;
        }

    .fi-wrap {
        position: relative;
    }

    .fi-changed-dot {
        position: absolute;
        right: -20px;
        top: 50%;
        transform: translateY(-50%);
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        box-shadow: 0 0 10px rgba(99,102,241,.6);
        opacity: 0;
        transition: opacity 250ms;
        pointer-events: none;
    }

        .fi-changed-dot.show {
            opacity: 1;
            animation: dotPop .3s cubic-bezier(.34,1.56,.64,1);
        }
    @@keyframes dotPop {
        from

    {
        transform: translateY(-50%) scale(0)
    }

    to {
        transform: translateY(-50%) scale(1)
    }

    }

    .fi-ctrl {
        width: 100%;
        height: 48px;
        border: 1.5px solid #e2e8f0;
        border-radius: 13px;
        background: #fafbfc;
        padding: 0 16px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 13.5px;
        color: #0f172a;
        outline: none;
        transition: all 220ms cubic-bezier(.4,0,.2,1);
        box-shadow: 0 1px 4px rgba(0,0,0,.04), inset 0 1px 0 rgba(255,255,255,.9);
    }

        .fi-ctrl:focus {
            border-color: #6366f1;
            background: #fff;
            box-shadow: 0 0 0 4px rgba(99,102,241,.10), 0 1px 4px rgba(0,0,0,.04);
        }

        .fi-ctrl:hover:not(:focus) {
            border-color: #c7d2fe;
            background: #fff;
        }

        .fi-ctrl::placeholder {
            color: #c4cdd9;
        }

        .fi-ctrl.changed {
            border-color: #6366f1;
            background: #fafaff;
            box-shadow: 0 0 0 3px rgba(99,102,241,.08);
        }

    .fi-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .fi-help {
        font-size: 11px;
        color: #94a3b8;
        font-weight: 500;
    }

    .fi-error {
        font-size: 11px;
        color: #f43f5e;
        font-weight: 600;
    }

    .char-count {
        font-size: 10px;
        color: #c4cdd9;
        font-family: 'DM Mono', monospace;
        transition: color 200ms;
    }

        .char-count.warn {
            color: #f59e0b;
        }

        .char-count.over {
            color: #f43f5e;
        }

    /* Status toggle card */
    .status-card {
        border-radius: 14px;
        overflow: hidden;
        border: 1.5px solid #e2e8f0;
        transition: all 250ms;
    }

        .status-card.on {
            border-color: #a7f3d0;
            background: linear-gradient(135deg, #f0fdf4, #ecfdf5);
        }

        .status-card.off {
            border-color: #e2e8f0;
            background: #fafbfc;
        }

    .status-card-inner {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 16px 20px;
    }

    .status-icon {
        width: 40px;
        height: 40px;
        border-radius: 11px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        flex-shrink: 0;
        transition: all 250ms;
    }

    .status-card.on .status-icon {
        background: #dcfce7;
        color: #10b981;
    }

    .status-card.off .status-icon {
        background: #f1f5f9;
        color: #94a3b8;
    }

    .status-texts {
        flex: 1;
    }

    .status-name {
        font-size: 14px;
        font-weight: 800;
        color: #0f172a;
        transition: color 200ms;
    }

    .status-desc {
        font-size: 11px;
        color: #94a3b8;
        margin-top: 2px;
    }

    /* Toggle switch */
    .sw {
        position: relative;
        width: 48px;
        height: 26px;
        flex-shrink: 0;
    }

        .sw input {
            opacity: 0;
            width: 0;
            height: 0;
            position: absolute;
        }

    .sw-track {
        position: absolute;
        inset: 0;
        border-radius: 26px;
        background: #e2e8f0;
        cursor: pointer;
        transition: background 250ms;
        border: 1px solid #d1d5db;
        box-shadow: inset 0 1px 3px rgba(0,0,0,.1);
    }

        .sw-track::after {
            content: '';
            position: absolute;
            top: 3px;
            left: 3px;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: #fff;
            box-shadow: 0 2px 5px rgba(0,0,0,.2);
            transition: transform 250ms cubic-bezier(.34,1.56,.64,1);
        }

    .sw input:checked ~ .sw-track {
        background: linear-gradient(135deg, #10b981, #06b6d4);
        border-color: transparent;
        box-shadow: 0 0 14px rgba(16,185,129,.4), inset 0 1px 0 rgba(255,255,255,.1);
    }

        .sw input:checked ~ .sw-track::after {
            transform: translateX(22px);
        }

    /* Footer */
    .uc-footer {
        padding: 18px 28px;
        border-top: 1px solid #f0f4f8;
        background: linear-gradient(135deg, #fafbff, #fafbfc);
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .btn-save {
        flex: 1;
        height: 50px;
        border: none;
        border-radius: 13px;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: #fff;
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 14px;
        font-weight: 800;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        box-shadow: 0 4px 20px rgba(99,102,241,.4), inset 0 1px 0 rgba(255,255,255,.18);
        transition: all 280ms cubic-bezier(.4,0,.2,1);
        position: relative;
        overflow: hidden;
    }

        .btn-save::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(255,255,255,.15) 0%, transparent 55%);
        }

        .btn-save::after {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            background: rgba(255,255,255,.15);
            border-radius: 50%;
            transform: translate(-50%,-50%);
            transition: width .4s, height .4s, opacity .4s;
        }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 28px rgba(99,102,241,.5);
        }

        .btn-save:active::after {
            width: 300px;
            height: 300px;
            opacity: 0;
        }

        .btn-save:active {
            transform: translateY(0);
        }

        .btn-save:disabled {
            opacity: .55;
            cursor: not-allowed;
            transform: none;
        }

    .change-badge {
        background: rgba(0,0,0,.18);
        padding: 2px 9px;
        border-radius: 20px;
        font-size: 11px;
        display: none;
        font-family: 'DM Mono', monospace;
    }

    .btn-cancel {
        height: 50px;
        padding: 0 24px;
        border: 1.5px solid #e2e8f0;
        border-radius: 13px;
        background: #fff;
        color: #475569;
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 13.5px;
        font-weight: 700;
        cursor: pointer;
        transition: all 220ms;
        box-shadow: 0 1px 4px rgba(0,0,0,.05);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .btn-cancel:hover {
            background: #f8fafc;
            border-color: #c7d2fe;
            color: #3730a3;
        }

    /* ── RIGHT PANEL ───────────────────────────────────────── */
    .uc-panel {
        position: sticky;
        top: 16px;
        display: flex;
        flex-direction: column;
        gap: 14px;
        animation: cardIn .4s .18s cubic-bezier(.4,0,.2,1) both;
    }

    .panel-card {
        background: #fff;
        border: 1px solid rgba(226,232,240,.9);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 14px rgba(0,0,0,.05), inset 0 1px 0 rgba(255,255,255,.95);
    }

    .pc-head {
        padding: 13px 16px 10px;
        border-bottom: 1px solid #f0f4f8;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .pc-title {
        font-size: 9.5px;
        font-weight: 800;
        letter-spacing: 1.8px;
        text-transform: uppercase;
        color: #94a3b8;
        font-family: 'DM Mono', monospace;
    }

    .pc-body {
        padding: 14px 16px;
    }

    /* Diff list */
    .diff-list {
        display: flex;
        flex-direction: column;
        gap: 7px;
        min-height: 38px;
    }

    .diff-empty {
        font-size: 12px;
        color: #c4cdd9;
        font-weight: 600;
        text-align: center;
        padding: 8px 0;
        font-style: italic;
    }

    .diff-item {
        display: flex;
        align-items: center;
        gap: 9px;
        padding: 8px 11px;
        border-radius: 9px;
        background: linear-gradient(135deg, #fafbff, #f5f3ff);
        border: 1px solid rgba(99,102,241,.15);
        animation: diffSlide .25s cubic-bezier(.34,1.56,.64,1) both;
    }
    @@keyframes diffSlide {
        from

    {
        opacity: 0;
        transform: translateX(-8px) scale(.95);
    }

    to {
        opacity: 1;
        transform: none;
    }

    }

    .diff-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        box-shadow: 0 0 8px rgba(99,102,241,.5);
    }

    .diff-name {
        font-size: 12px;
        font-weight: 700;
        color: #4338ca;
    }

    /* Color swatches */
    .color-swatches {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 7px;
    }

    .swatch {
        height: 38px;
        border-radius: 10px;
        cursor: pointer;
        border: 2px solid transparent;
        transition: all 200ms;
        position: relative;
        overflow: hidden;
    }

        .swatch::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(255,255,255,.22) 0%, transparent 60%);
        }

        .swatch:hover {
            transform: scale(1.07);
        }

        .swatch.selected {
            border-color: #0f172a;
            box-shadow: 0 0 0 2px #fff, 0 0 0 4px #0f172a;
        }

        .swatch .ck {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            color: #fff;
            opacity: 0;
            transition: opacity 200ms;
            z-index: 1;
        }

        .swatch.selected .ck {
            opacity: 1;
        }

    /* Info items */
    .info-row {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 12px;
        border-radius: 10px;
        background: #f8fafc;
        border: 1px solid #f0f4f8;
        margin-bottom: 8px;
    }

        .info-row:last-child {
            margin-bottom: 0;
        }

    .info-row-ic {
        width: 28px;
        height: 28px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        flex-shrink: 0;
    }

    .info-row-label {
        font-size: 10px;
        font-weight: 700;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: .5px;
    }

    .info-row-val {
        font-size: 12px;
        font-weight: 700;
        color: #0f172a;
        margin-top: 1px;
        font-family: 'DM Mono', monospace;
        word-break: break-all;
    }

    /* Tips */
    .tips-card {
        border-radius: 16px;
        background: linear-gradient(150deg, #0f172a 0%, #1e1b4b 100%);
        border: 1px solid rgba(99,102,241,.22);
        box-shadow: 0 6px 24px rgba(0,0,0,.18), inset 0 1px 0 rgba(255,255,255,.04);
        overflow: hidden;
        position: relative;
    }

        .tips-card::before {
            content: '';
            position: absolute;
            top: -24px;
            right: -24px;
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(99,102,241,.28) 0%, transparent 70%);
            pointer-events: none;
        }

    .tips-head {
        padding: 14px 16px 8px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .tips-title {
        font-size: 12px;
        font-weight: 800;
        color: #fff;
    }

    .tips-body {
        padding: 0 16px 14px;
    }

    .tip-row {
        display: flex;
        gap: 8px;
        margin-top: 9px;
        font-size: 11px;
        line-height: 1.5;
        color: rgba(226,232,240,.6);
    }

    .tip-ic {
        color: #818cf8;
        font-size: 11px;
        margin-top: 1px;
        flex-shrink: 0;
    }
</style>

<input type="hidden" id="selectedColor" value="linear-gradient(135deg,#3b82f6,#6366f1)" />

<!-- Edit Banner -->
<div class="edit-banner">
    <div class="eb-left">
        <div class="eb-icon"><i class="fa-solid fa-pen-nib"></i></div>
        <div class="eb-texts">
            <div class="eb-title">Edit Mode — <span id="bannerName">@Model.CategoryName</span></div>
            <div class="eb-sub">Changes are not applied until you save</div>
        </div>
    </div>
    <div class="eb-right">
        <div class="eb-id">@Model.CategoryId</div>
        <div class="eb-pulse"></div>
    </div>
</div>

<!-- Page Header -->
<div class="ph anim" style="margin-bottom:22px;">
    <div>
        <div class="ph-eye">Categories</div>
        <h1 class="ph-h1">Update Category</h1>
        <p class="ph-desc">Edit category name and visibility status</p>
    </div>
    <div class="ph-acts">
        <a href="@Url.Action("CategoryList", "Category")" class="btn btn-ghost">
            <i class="fa-solid fa-arrow-left"></i> Back
        </a>
    </div>
</div>

<form asp-action="UpdateCategory" asp-controller="Category" method="post" id="ucForm">
    @Html.AntiForgeryToken()
    <input asp-for="CategoryId" type="hidden" />

    <div class="uc-layout">

        <!-- ══ LEFT ════════════════════════════════════════════ -->
        <div>
            <div class="uc-card">

                <div class="uc-card-head">
                    <div class="uc-head-icon"><i class="fa-solid fa-layer-group"></i></div>
                    <div>
                        <div class="uc-head-title">Category Details</div>
                        <div class="uc-head-sub">Update the name and publication status</div>
                    </div>
                </div>

                <div class="uc-body">

                    <!-- Hero preview -->
                    <div class="hero-preview" id="heroPreview">
                        <div class="hero-orb hero-orb-1"></div>
                        <div class="hero-orb hero-orb-2"></div>
                        <div class="hero-avatar-wrap">
                            <div class="hero-avatar-ring"></div>
                            <div class="hero-avatar" id="heroAvatar"
                                 style="background:linear-gradient(135deg,#3b82f6,#6366f1);">
                                <span id="heroInitial">@(Model.CategoryName?.Length > 0 ? char.ToUpper(Model.CategoryName[0]).ToString() : "?")</span>
                            </div>
                        </div>
                        <div class="hero-info">
                            <div class="hero-eyebrow">Category Preview</div>
                            <div class="hero-name @(string.IsNullOrEmpty(Model.CategoryName) ? "placeholder" : "")" id="heroName">
                                @(string.IsNullOrEmpty(Model.CategoryName) ? "Start typing a name..." : Model.CategoryName)
                            </div>
                            <div class="hero-status @(Model.CategoryStatus ? "on" : "off")" id="heroStatus">
                                <span class="hero-status-dot"></span>
                                <span id="heroStatusText">@(Model.CategoryStatus ? "Active" : "Passive")</span>
                            </div>
                        </div>
                    </div>

                    <div class="fields-grid">

                        <!-- CategoryName -->
                        <div class="fg">
                            <label class="fl">
                                <i class="fa-solid fa-tag"></i>
                                Category Name <span class="req">*</span>
                            </label>
                            <div class="fi-wrap">
                                <input asp-for="CategoryName" class="fi-ctrl" id="CategoryName"
                                       placeholder="e.g. Kültür & Tarih"
                                       maxlength="60"
                                       data-original="@Model.CategoryName"
                                       oninput="trackChange(this,'CategoryName');syncPreview()" />
                                <div class="fi-changed-dot" id="dot-CategoryName"></div>
                            </div>
                            <div class="fi-footer" style="margin-top:4px;">
                                <span asp-validation-for="CategoryName" class="fi-error"></span>
                                <div class="char-count" id="nameCount">@(Model.CategoryName?.Length ?? 0) / 60</div>
                            </div>
                        </div>

                        <!-- Status -->
                        <div class="fg">
                            <label class="fl"><i class="fa-solid fa-eye"></i> Visibility Status</label>
                            <div class="status-card @(Model.CategoryStatus ? "on" : "off")" id="statusCard">
                                <div class="status-card-inner">
                                    <div class="status-icon">
                                        <i class="fa-solid @(Model.CategoryStatus ? "fa-eye" : "fa-eye-slash")" id="statusIcon"></i>
                                    </div>
                                    <div class="status-texts">
                                        <div class="status-name" id="statusName">@(Model.CategoryStatus ? "Active" : "Passive")</div>
                                        <div class="status-desc" id="statusDesc">
                                            @(Model.CategoryStatus ? "Category is visible in listings" : "Category is hidden from listings")
                                        </div>
                                    </div>
                                    <label class="sw">
                                        <input asp-for="CategoryStatus" type="checkbox" id="CategoryStatus"
                                               onchange="syncStatus(this)" />
                                        <div class="sw-track"></div>
                                    </label>
                                </div>
                            </div>
                        </div>

                    </div>

                </div>

                <div class="uc-footer">
                    <button type="submit" class="btn-save" id="saveBtn">
                        <i class="fa-solid fa-floppy-disk"></i>
                        Save Changes
                        <span class="change-badge" id="changeBadge"></span>
                    </button>
                    <a href="@Url.Action("CategoryList", "Category")" class="btn-cancel">
                        <i class="fa-solid fa-xmark"></i> Cancel
                    </a>
                </div>

            </div>
        </div>

        <!-- ══ RIGHT PANEL ══════════════════════════════════════ -->
        <div class="uc-panel">

            <!-- Changed fields -->
            <div class="panel-card">
                <div class="pc-head">
                    <div class="pc-title">Changed Fields</div>
                    <div id="diffBadge" style="display:none;font-size:10px;font-weight:800;
                     font-family:'DM Mono',monospace;background:linear-gradient(135deg,#6366f1,#8b5cf6);
                     color:#fff;padding:2px 9px;border-radius:20px;box-shadow:0 2px 8px rgba(99,102,241,.3);">
                        0
                    </div>
                </div>
                <div class="pc-body">
                    <div class="diff-list" id="diffList">
                        <div class="diff-empty" id="diffEmpty">No changes yet</div>
                    </div>
                </div>
            </div>

            <!-- Color picker -->
            <div class="panel-card">
                <div class="pc-head"><div class="pc-title">Avatar Color</div></div>
                <div class="pc-body">
                    <div class="color-swatches">
                        <div class="swatch selected" onclick="pickColor(this)"
                             data-grad="linear-gradient(135deg,#3b82f6,#6366f1)"
                             style="background:linear-gradient(135deg,#3b82f6,#6366f1)">
                            <div class="ck"><i class="fa-solid fa-check"></i></div>
                        </div>
                        <div class="swatch" onclick="pickColor(this)"
                             data-grad="linear-gradient(135deg,#10b981,#06b6d4)"
                             style="background:linear-gradient(135deg,#10b981,#06b6d4)">
                            <div class="ck"><i class="fa-solid fa-check"></i></div>
                        </div>
                        <div class="swatch" onclick="pickColor(this)"
                             data-grad="linear-gradient(135deg,#f59e0b,#f97316)"
                             style="background:linear-gradient(135deg,#f59e0b,#f97316)">
                            <div class="ck"><i class="fa-solid fa-check"></i></div>
                        </div>
                        <div class="swatch" onclick="pickColor(this)"
                             data-grad="linear-gradient(135deg,#8b5cf6,#ec4899)"
                             style="background:linear-gradient(135deg,#8b5cf6,#ec4899)">
                            <div class="ck"><i class="fa-solid fa-check"></i></div>
                        </div>
                        <div class="swatch" onclick="pickColor(this)"
                             data-grad="linear-gradient(135deg,#f43f5e,#f97316)"
                             style="background:linear-gradient(135deg,#f43f5e,#f97316)">
                            <div class="ck"><i class="fa-solid fa-check"></i></div>
                        </div>
                        <div class="swatch" onclick="pickColor(this)"
                             data-grad="linear-gradient(135deg,#06b6d4,#6366f1)"
                             style="background:linear-gradient(135deg,#06b6d4,#6366f1)">
                            <div class="ck"><i class="fa-solid fa-check"></i></div>
                        </div>
                    </div>
                    <div style="font-size:11px;color:#94a3b8;margin-top:9px;">Visual only — not saved</div>
                </div>
            </div>

            <!-- Category info -->
            <div class="panel-card">
                <div class="pc-head"><div class="pc-title">Category Info</div></div>
                <div class="pc-body">
                    <div class="info-row">
                        <div class="info-row-ic" style="background:#f5f3ff;color:#6366f1;">
                            <i class="fa-solid fa-fingerprint"></i>
                        </div>
                        <div>
                            <div class="info-row-label">Category ID</div>
                            <div class="info-row-val">@(Model.CategoryId?.Length > 14 ? Model.CategoryId[..14] + "…" : Model.CategoryId)</div>
                        </div>
                    </div>
                    <div class="info-row">
                        <div class="info-row-ic" style="background:#f0fdf4;color:#10b981;">
                            <i class="fa-solid fa-circle-dot"></i>
                        </div>
                        <div>
                            <div class="info-row-label">Current Status</div>
                            <div class="info-row-val" id="infoStatus" style="color:@(Model.CategoryStatus ? "#10b981" : "#94a3b8")">
                                @(Model.CategoryStatus ? "Active" : "Passive")
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tips -->
            <div class="tips-card">
                <div class="tips-head">
                    <i class="fa-solid fa-lightbulb" style="color:#fbbf24;"></i>
                    <div class="tips-title">Update Tips</div>
                </div>
                <div class="tips-body">
                    <div class="tip-row">
                        <i class="fa-solid fa-circle-dot tip-ic"></i>
                        <span>Name changes affect all tours linked to this category.</span>
                    </div>
                    <div class="tip-row">
                        <i class="fa-solid fa-circle-dot tip-ic"></i>
                        <span>Passive hides the category without deleting it.</span>
                    </div>
                    <div class="tip-row">
                        <i class="fa-solid fa-circle-dot tip-ic"></i>
                        <span>Keep names short, descriptive and consistent.</span>
                    </div>
                </div>
            </div>

        </div>

    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        const origName   = "@Model.CategoryName";
        const origStatus = @(Model.CategoryStatus ? "true" : "false");
        const changed    = new Set();
        const LABELS     = { CategoryName: 'Category Name', CategoryStatus: 'Status' };

        /* ── Track ───────────────────────────────────────────────── */
        function trackChange(el, key) {
            const orig = el.dataset.original ?? '';
            const dot  = document.getElementById('dot-' + key);
            if (el.value !== orig) {
                changed.add(key); el.classList.add('changed');
                if (dot) dot.classList.add('show');
            } else {
                changed.delete(key); el.classList.remove('changed');
                if (dot) dot.classList.remove('show');
            }
            if (key === 'CategoryName') updateCC(el.value.length);
            renderDiff();
        }

        /* ── Char counter ────────────────────────────────────────── */
        function updateCC(n) {
            const el = document.getElementById('nameCount');
            el.textContent = n + ' / 60';
            el.className = 'char-count' + (n > 50 ? ' warn' : '') + (n >= 60 ? ' over' : '');
        }

        /* ── Sync preview ────────────────────────────────────────── */
        function syncPreview() {
            const val       = document.getElementById('CategoryName').value.trim();
            const heroName  = document.getElementById('heroName');
            const heroInit  = document.getElementById('heroInitial');
            const bannerN   = document.getElementById('bannerName');

            if (val) {
                heroName.textContent = val;
                heroName.classList.remove('placeholder');
                heroInit.textContent = val[0].toUpperCase();
                if (bannerN) bannerN.textContent = val;
            } else {
                heroName.textContent = 'Start typing a name...';
                heroName.classList.add('placeholder');
                heroInit.textContent = '?';
            }
        }

        /* ── Status sync ─────────────────────────────────────────── */
        function syncStatus(cb) {
            const on = cb.checked;
            const card     = document.getElementById('statusCard');
            const sName    = document.getElementById('statusName');
            const sDesc    = document.getElementById('statusDesc');
            const sIcon    = document.getElementById('statusIcon');
            const hStatus  = document.getElementById('heroStatus');
            const hStText  = document.getElementById('heroStatusText');
            const infoSt   = document.getElementById('infoStatus');

            card.className  = 'status-card ' + (on ? 'on' : 'off');
            sName.textContent = on ? 'Active' : 'Passive';
            sDesc.textContent = on ? 'Category is visible in listings' : 'Category is hidden from listings';
            sIcon.className   = 'fa-solid ' + (on ? 'fa-eye' : 'fa-eye-slash');
            hStatus.className = 'hero-status ' + (on ? 'on' : 'off');
            hStText.textContent = on ? 'Active' : 'Passive';
            infoSt.textContent  = on ? 'Active' : 'Passive';
            infoSt.style.color  = on ? '#10b981' : '#94a3b8';

            if (on !== origStatus) changed.add('CategoryStatus');
            else changed.delete('CategoryStatus');
            renderDiff();
        }

        /* ── Color picker ────────────────────────────────────────── */
        function pickColor(el) {
            document.querySelectorAll('.swatch').forEach(s => s.classList.remove('selected'));
            el.classList.add('selected');
            document.getElementById('heroAvatar').style.background = el.dataset.grad;
            document.getElementById('selectedColor').value = el.dataset.grad;
        }

        /* ── Diff render ─────────────────────────────────────────── */
        function renderDiff() {
            const list  = document.getElementById('diffList');
            const empty = document.getElementById('diffEmpty');
            const badge = document.getElementById('diffBadge');
            const cb    = document.getElementById('changeBadge');

            list.querySelectorAll('.diff-item').forEach(e => e.remove());

            if (changed.size === 0) {
                empty.style.display = 'block';
                badge.style.display = 'none';
                cb.style.display    = 'none';
                return;
            }
            empty.style.display = 'none';
            badge.style.display = 'block';
            badge.textContent   = changed.size;
            cb.style.display    = 'inline-flex';
            cb.textContent      = changed.size + (changed.size === 1 ? ' change' : ' changes');

            changed.forEach(key => {
                const d = document.createElement('div');
                d.className = 'diff-item';
                d.innerHTML = `<div class="diff-dot"></div><div class="diff-name">${LABELS[key]||key}</div>`;
                list.appendChild(d);
            });
        }

        /* ── Submit ──────────────────────────────────────────────── */
        document.getElementById('ucForm').addEventListener('submit', () => {
            const btn = document.getElementById('saveBtn');
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Saving...';
            btn.disabled = true;
        });

        /* ── Init ────────────────────────────────────────────────── */
        updateCC(document.getElementById('CategoryName').value.length);
    </script>
}
