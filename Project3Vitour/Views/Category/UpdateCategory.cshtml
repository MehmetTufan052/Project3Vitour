@model Project3Vitour.Dtos.CategoryDto.UpdateCategoryDto
@{
    ViewData["Title"] = "UpdateCategory";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    /* ══════════════════════════════════════════════════════════
       UPDATE CATEGORY
    ══════════════════════════════════════════════════════════ */

    .uc-layout {
        display: grid;
        grid-template-columns: 1fr 290px;
        gap: 20px;
        align-items: start;
        max-width: 900px;
    }
    @@media (max-width: 1024px) {
        .uc-layout

    {
        grid-template-columns: 1fr;
        max-width: 100%;
    }

    }

    /* Edit banner */
    .edit-banner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        padding: 13px 20px;
        border-radius: 14px;
        margin-bottom: 20px;
        background: linear-gradient(135deg, rgba(99,102,241,.10), rgba(139,92,246,.06));
        border: 1px solid rgba(99,102,241,.25);
        backdrop-filter: blur(12px);
        box-shadow: 0 2px 16px rgba(99,102,241,.08), inset 0 1px 0 rgba(255,255,255,.06);
        animation: ucIn .4s cubic-bezier(.4,0,.2,1) both;
    }
    @@keyframes ucIn {
        from

    {
        opacity: 0;
        transform: translateY(-8px)
    }

    to {
        opacity: 1;
        transform: none
    }

    }

    .eb-left {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .eb-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
        color: #fff;
        flex-shrink: 0;
        box-shadow: 0 0 16px rgba(99,102,241,.35);
        position: relative;
    }

        .eb-icon::after {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: inherit;
            background: linear-gradient(180deg, rgba(255,255,255,.2) 0%, transparent 60%);
        }

    .eb-title {
        font-size: 13.5px;
        font-weight: 800;
        color: #4338ca;
    }

    .eb-sub {
        font-size: 11px;
        color: #6366f1;
        margin-top: 1px;
        opacity: .8;
    }

    .eb-id {
        font-size: 10px;
        font-family: 'DM Mono', monospace;
        color: #6366f1;
        background: rgba(99,102,241,.10);
        padding: 4px 10px;
        border-radius: 8px;
        border: 1px solid rgba(99,102,241,.18);
        white-space: nowrap;
        letter-spacing: .5px;
    }

    /* ── MAIN CARD ─────────────────────────────────────────── */
    .uc-card {
        background: #fff;
        border: 1px solid rgba(226,232,240,.9);
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 2px 16px rgba(0,0,0,.06), inset 0 1px 0 rgba(255,255,255,.95);
        animation: ucIn .35s .04s cubic-bezier(.4,0,.2,1) both;
    }

    .uc-card-head {
        padding: 20px 24px 16px;
        border-bottom: 1px solid #f0f4f8;
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .uc-head-icon {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 17px;
        color: #fff;
        flex-shrink: 0;
        box-shadow: 0 0 18px rgba(99,102,241,.35);
        position: relative;
    }

        .uc-head-icon::after {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: inherit;
            background: linear-gradient(180deg, rgba(255,255,255,.2) 0%, transparent 60%);
        }

    .uc-head-title {
        font-size: 15px;
        font-weight: 800;
        color: #0f172a;
        letter-spacing: -.3px;
    }

    .uc-head-sub {
        font-size: 11.5px;
        color: #94a3b8;
        margin-top: 2px;
    }

    .uc-body {
        padding: 26px;
    }

    /* ── CATEGORY PREVIEW ──────────────────────────────────── */
    .cat-preview-box {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 18px 20px;
        border-radius: 14px;
        margin-bottom: 24px;
        background: linear-gradient(135deg, #fafbff 0%, #f5f3ff 100%);
        border: 1px solid #e0e7ff;
        position: relative;
        overflow: hidden;
        transition: all 300ms;
    }

        .cat-preview-box::before {
            content: '';
            position: absolute;
            top: -20px;
            right: -20px;
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(99,102,241,.12) 0%, transparent 70%);
            pointer-events: none;
        }

    .cat-prev-avatar {
        width: 52px;
        height: 52px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        font-weight: 900;
        color: #fff;
        flex-shrink: 0;
        position: relative;
        overflow: hidden;
        transition: all 300ms cubic-bezier(.34,1.56,.64,1);
        box-shadow: 0 4px 14px rgba(99,102,241,.3);
    }

        .cat-prev-avatar::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(255,255,255,.2) 0%, transparent 60%);
        }

    .cat-prev-name {
        font-size: 18px;
        font-weight: 800;
        color: #1e1b4b;
        letter-spacing: -.4px;
        line-height: 1.2;
        transition: all 200ms;
    }

        .cat-prev-name.placeholder {
            color: #c4cdd9;
            font-weight: 400;
            font-style: italic;
            font-size: 15px;
        }

    .cat-prev-label {
        font-size: 9.5px;
        font-weight: 800;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #a5b4fc;
        font-family: 'DM Mono', monospace;
        margin-bottom: 4px;
    }

    /* ── FIELDS ────────────────────────────────────────────── */
    .fg {
        display: flex;
        flex-direction: column;
        gap: 6px;
        margin-bottom: 18px;
    }

        .fg:last-child {
            margin-bottom: 0;
        }

    .fl {
        font-size: 10.5px;
        font-weight: 800;
        color: #475569;
        letter-spacing: .6px;
        text-transform: uppercase;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .fl i {
            color: #a5b4fc;
            font-size: 11px;
            width: 13px;
            text-align: center;
        }

        .fl .req {
            color: #f43f5e;
            font-size: 13px;
            text-transform: none;
            letter-spacing: 0;
        }

    .fi-wrap {
        position: relative;
    }

    .fi-changed-dot {
        position: absolute;
        right: -18px;
        top: 50%;
        transform: translateY(-50%);
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        box-shadow: 0 0 8px rgba(99,102,241,.5);
        opacity: 0;
        transition: opacity 250ms;
        pointer-events: none;
    }

        .fi-changed-dot.show {
            opacity: 1;
        }

    .fi-ctrl {
        width: 100%;
        height: 46px;
        border: 1.5px solid #e2e8f0;
        border-radius: 12px;
        background: #fafbfc;
        padding: 0 14px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 13px;
        color: #0f172a;
        outline: none;
        transition: all 200ms cubic-bezier(.4,0,.2,1);
        box-shadow: 0 1px 3px rgba(0,0,0,.04), inset 0 1px 0 rgba(255,255,255,.8);
    }

        .fi-ctrl:focus {
            border-color: #6366f1;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(99,102,241,.10), 0 1px 3px rgba(0,0,0,.04);
        }

        .fi-ctrl:hover:not(:focus) {
            border-color: #cbd5e1;
            background: #fff;
        }

        .fi-ctrl::placeholder {
            color: #c4cdd9;
        }

        .fi-ctrl.changed {
            border-color: #6366f1;
            background: #fafbff;
            box-shadow: 0 0 0 3px rgba(99,102,241,.07);
        }

    .fi-help {
        font-size: 11px;
        color: #94a3b8;
        font-weight: 500;
        margin-top: 3px;
    }

    .fi-error {
        font-size: 11px;
        color: #f43f5e;
        font-weight: 600;
        margin-top: 3px;
    }

    .char-count {
        font-size: 10px;
        color: #c4cdd9;
        text-align: right;
        font-family: 'DM Mono', monospace;
        margin-top: 3px;
        transition: color 200ms;
    }

        .char-count.warn {
            color: #f59e0b;
        }

        .char-count.over {
            color: #f43f5e;
        }

    /* Status toggle */
    .sw-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 13px 16px;
        border-radius: 12px;
        background: #fafbfc;
        border: 1px solid #f1f5f9;
        transition: all 200ms;
    }

        .sw-row.on {
            background: #f0fdf4;
            border-color: #bbf7d0;
        }

        .sw-row.off {
            background: #fafbfc;
            border-color: #f1f5f9;
        }

    .sw-info .swn {
        font-size: 13px;
        font-weight: 700;
        color: #0f172a;
        transition: color 200ms;
    }

    .sw-info .sws {
        font-size: 10.5px;
        color: #94a3b8;
        margin-top: 1px;
    }

    .sw {
        position: relative;
        width: 44px;
        height: 24px;
        flex-shrink: 0;
    }

        .sw input {
            opacity: 0;
            width: 0;
            height: 0;
            position: absolute;
        }

    .sw-track {
        position: absolute;
        inset: 0;
        border-radius: 24px;
        background: #e2e8f0;
        cursor: pointer;
        transition: background 200ms;
        border: 1px solid #d1d5db;
    }

        .sw-track::after {
            content: '';
            position: absolute;
            top: 3px;
            left: 3px;
            width: 16px;
            height: 16px;
            border-radius: 50%;
            background: #fff;
            box-shadow: 0 1px 4px rgba(0,0,0,.18);
            transition: transform 200ms cubic-bezier(.34,1.56,.64,1);
        }

    .sw input:checked ~ .sw-track {
        background: linear-gradient(135deg, #10b981, #06b6d4);
        border-color: transparent;
        box-shadow: 0 0 12px rgba(16,185,129,.35);
    }

        .sw input:checked ~ .sw-track::after {
            transform: translateX(20px);
        }

    /* Footer */
    .uc-footer {
        padding: 16px 24px;
        border-top: 1px solid #f0f4f8;
        background: #fafbfc;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .btn-save {
        flex: 1;
        height: 48px;
        border: none;
        border-radius: 12px;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: #fff;
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 14px;
        font-weight: 800;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        box-shadow: 0 3px 16px rgba(99,102,241,.38), inset 0 1px 0 rgba(255,255,255,.15);
        transition: all 250ms;
        position: relative;
        overflow: hidden;
    }

        .btn-save::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(255,255,255,.14) 0%, transparent 55%);
        }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 24px rgba(99,102,241,.48);
        }

        .btn-save:active {
            transform: translateY(0);
        }

        .btn-save:disabled {
            opacity: .55;
            cursor: not-allowed;
            transform: none;
        }

    .btn-cancel {
        height: 48px;
        padding: 0 22px;
        border: 1.5px solid #e2e8f0;
        border-radius: 12px;
        background: #fff;
        color: #475569;
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 13.5px;
        font-weight: 700;
        cursor: pointer;
        transition: all 200ms;
        box-shadow: 0 1px 3px rgba(0,0,0,.04);
        text-decoration: none;
        display: flex;
        align-items: center;
    }

        .btn-cancel:hover {
            background: #f8fafc;
            border-color: #cbd5e1;
            color: #0f172a;
        }

    /* ── RIGHT PANEL ───────────────────────────────────────── */
    .uc-panel {
        position: sticky;
        top: 16px;
        display: flex;
        flex-direction: column;
        gap: 14px;
        animation: ucIn .35s .18s cubic-bezier(.4,0,.2,1) both;
    }

    .panel-card {
        background: #fff;
        border: 1px solid rgba(226,232,240,.9);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0,0,0,.05), inset 0 1px 0 rgba(255,255,255,.95);
    }

    .pc-head {
        padding: 13px 16px 9px;
        border-bottom: 1px solid #f0f4f8;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .pc-title {
        font-size: 9.5px;
        font-weight: 800;
        letter-spacing: 1.8px;
        text-transform: uppercase;
        color: #94a3b8;
        font-family: 'DM Mono', monospace;
    }

    .pc-body {
        padding: 14px 16px;
    }

    /* Diff list */
    .diff-list {
        display: flex;
        flex-direction: column;
        gap: 6px;
        min-height: 36px;
    }

    .diff-empty {
        font-size: 12px;
        color: #c4cdd9;
        font-weight: 600;
        text-align: center;
        padding: 8px 0;
        font-style: italic;
    }

    .diff-item {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 7px 10px;
        border-radius: 8px;
        background: #fafbff;
        border: 1px solid rgba(99,102,241,.15);
        animation: diffIn .2s cubic-bezier(.34,1.56,.64,1) both;
    }
    @@keyframes diffIn {
        from

    {
        opacity: 0;
        transform: scale(.92)translateX(-6px)
    }

    to {
        opacity: 1;
        transform: none
    }

    }

    .diff-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        box-shadow: 0 0 6px rgba(99,102,241,.5);
    }

    .diff-name {
        font-size: 12px;
        font-weight: 700;
        color: #4338ca;
    }

    .diff-badge-count {
        margin-left: auto;
        font-size: 10px;
        font-weight: 800;
        font-family: 'DM Mono', monospace;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: #fff;
        padding: 2px 7px;
        border-radius: 20px;
    }

    /* Color swatches */
    .color-swatches {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 6px;
    }

    .swatch {
        height: 36px;
        border-radius: 9px;
        cursor: pointer;
        border: 2px solid transparent;
        transition: all 200ms;
        position: relative;
        overflow: hidden;
    }

        .swatch::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(255,255,255,.2) 0%, transparent 60%);
        }

        .swatch:hover {
            transform: scale(1.06);
        }

        .swatch.selected {
            border-color: #0f172a;
            box-shadow: 0 0 0 2px #fff, 0 0 0 4px #0f172a;
        }

        .swatch .check-ic {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            color: #fff;
            opacity: 0;
            transition: opacity 200ms;
            z-index: 1;
        }

        .swatch.selected .check-ic {
            opacity: 1;
        }

    /* Tips */
    .tips-card {
        border-radius: 16px;
        background: linear-gradient(150deg, #0f172a 0%, #1e1b4b 100%);
        border: 1px solid rgba(99,102,241,.2);
        box-shadow: 0 4px 20px rgba(0,0,0,.15), inset 0 1px 0 rgba(255,255,255,.04);
        overflow: hidden;
        position: relative;
    }

        .tips-card::before {
            content: '';
            position: absolute;
            top: -20px;
            right: -20px;
            width: 90px;
            height: 90px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(99,102,241,.25) 0%, transparent 70%);
            pointer-events: none;
        }

    .tips-head {
        padding: 13px 16px 8px;
        display: flex;
        align-items: center;
        gap: 7px;
    }

    .tips-title {
        font-size: 12px;
        font-weight: 800;
        color: #fff;
    }

    .tips-body {
        padding: 0 16px 14px;
    }

    .tip-row {
        display: flex;
        gap: 8px;
        margin-top: 9px;
        font-size: 11px;
        line-height: 1.5;
        color: rgba(226,232,240,.65);
    }

    .tip-ic {
        color: #818cf8;
        font-size: 11px;
        margin-top: 1px;
        flex-shrink: 0;
    }
</style>

<!-- Hidden color field -->
<input type="hidden" id="selectedColor" value="linear-gradient(135deg,#3b82f6,#6366f1)" />

<!-- Edit banner -->
<div class="edit-banner">
    <div class="eb-left">
        <div class="eb-icon"><i class="fa-solid fa-pen-to-square"></i></div>
        <div>
            <div class="eb-title">Edit Mode — @Model.CategoryName</div>
            <div class="eb-sub">Changes won't apply until saved</div>
        </div>
    </div>
    <div class="eb-id">ID: @Model.CategoryId</div>
</div>

<!-- Page header -->
<div class="ph anim" style="margin-bottom:20px;">
    <div>
        <div class="ph-eye">Categories</div>
        <h1 class="ph-h1">Update Category</h1>
        <p class="ph-desc">Edit the category details below</p>
    </div>
    <div class="ph-acts">
        <a href="@Url.Action("CategoryList", "AdminCategory")" class="btn btn-ghost">
            <i class="fa-solid fa-arrow-left"></i> Back
        </a>
    </div>
</div>

<form asp-action="UpdateCategory" asp-controller="AdminCategory" method="post" id="ucForm">
    @Html.AntiForgeryToken()
    <input asp-for="CategoryId" type="hidden" />

    <div class="uc-layout">

        <!-- ══ LEFT ════════════════════════════════════════════ -->
        <div>
            <div class="uc-card">

                <div class="uc-card-head">
                    <div class="uc-head-icon"><i class="fa-solid fa-layer-group"></i></div>
                    <div>
                        <div class="uc-head-title">Category Details</div>
                        <div class="uc-head-sub">Update name and visibility status</div>
                    </div>
                </div>

                <div class="uc-body">

                    <!-- Live preview -->
                    <div class="cat-preview-box" id="previewBox">
                        <div class="cat-prev-avatar" id="prevAvatar"
                             style="background:linear-gradient(135deg,#3b82f6,#6366f1);">
                            <span id="prevInitial">@(Model.CategoryName?.Length > 0 ? char.ToUpper(Model.CategoryName[0]).ToString() : "?")</span>
                        </div>
                        <div>
                            <div class="cat-prev-label">Category Name</div>
                            <div class="cat-prev-name @(string.IsNullOrEmpty(Model.CategoryName) ? "placeholder" : "")" id="prevName">
                                @(string.IsNullOrEmpty(Model.CategoryName) ? "Enter a name below..." : Model.CategoryName)
                            </div>
                        </div>
                    </div>

                    <!-- CategoryName -->
                    <div class="fg">
                        <label class="fl">
                            <i class="fa-solid fa-tag"></i>
                            Category Name <span class="req">*</span>
                        </label>
                        <div class="fi-wrap">
                            <input asp-for="CategoryName" class="fi-ctrl" id="CategoryName"
                                   placeholder="e.g. Kültür & Tarih"
                                   maxlength="60"
                                   data-original="@Model.CategoryName"
                                   oninput="trackChange(this,'CategoryName');updatePreview()" />
                            <div class="fi-changed-dot" id="dot-CategoryName"></div>
                        </div>
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-top:2px;">
                            <span asp-validation-for="CategoryName" class="fi-error"></span>
                            <div class="char-count" id="nameCount" style="margin-left:auto;">
                                @(Model.CategoryName?.Length ?? 0) / 60
                            </div>
                        </div>
                    </div>

                    <!-- Status -->
                    <div class="fg">
                        <label class="fl"><i class="fa-solid fa-toggle-on"></i> Status</label>
                        <div class="sw-row @(Model.CategoryStatus ? "on" : "off")" id="swRow">
                            <div class="sw-info">
                                <div class="swn" id="swLabel">@(Model.CategoryStatus ? "Active" : "Passive")</div>
                                <div class="sws" id="swDesc">@(Model.CategoryStatus ? "Category is publicly visible" : "Category won't be visible")</div>
                            </div>
                            <label class="sw">
                                <input asp-for="CategoryStatus" type="checkbox" id="CategoryStatus"
                                       onchange="syncStatus(this)" />
                                <div class="sw-track"></div>
                            </label>
                        </div>
                    </div>

                </div>

                <div class="uc-footer">
                    <button type="submit" class="btn-save" id="saveBtn">
                        <i class="fa-solid fa-floppy-disk"></i> Save Changes
                        <span id="changeCount" style="background:rgba(0,0,0,.15);padding:2px 8px;border-radius:20px;font-size:11px;display:none;"></span>
                    </button>
                    <a href="@Url.Action("CategoryList", "Category")" class="btn-cancel">
                        Cancel
                    </a>
                </div>

            </div>
        </div>

        <!-- ══ RIGHT PANEL ══════════════════════════════════════ -->
        <div class="uc-panel">

            <!-- Changed fields -->
            <div class="panel-card">
                <div class="pc-head">
                    <div class="pc-title">Changed Fields</div>
                    <div id="diffBadge" style="display:none;font-size:10px;font-weight:800;font-family:'DM Mono',monospace;background:linear-gradient(135deg,#6366f1,#8b5cf6);color:#fff;padding:2px 9px;border-radius:20px;box-shadow:0 2px 8px rgba(99,102,241,.3);">0</div>
                </div>
                <div class="pc-body">
                    <div class="diff-list" id="diffList">
                        <div class="diff-empty" id="diffEmpty">No changes yet</div>
                    </div>
                </div>
            </div>

            <!-- Avatar color picker -->
            <div class="panel-card">
                <div class="pc-head"><div class="pc-title">Avatar Color</div></div>
                <div class="pc-body">
                    <div class="color-swatches" id="swatches">
                        <div class="swatch selected" data-grad="linear-gradient(135deg,#3b82f6,#6366f1)"
                             onclick="pickColor(this)" style="background:linear-gradient(135deg,#3b82f6,#6366f1)">
                            <div class="check-ic"><i class="fa-solid fa-check"></i></div>
                        </div>
                        <div class="swatch" data-grad="linear-gradient(135deg,#10b981,#06b6d4)"
                             onclick="pickColor(this)" style="background:linear-gradient(135deg,#10b981,#06b6d4)">
                            <div class="check-ic"><i class="fa-solid fa-check"></i></div>
                        </div>
                        <div class="swatch" data-grad="linear-gradient(135deg,#f59e0b,#f97316)"
                             onclick="pickColor(this)" style="background:linear-gradient(135deg,#f59e0b,#f97316)">
                            <div class="check-ic"><i class="fa-solid fa-check"></i></div>
                        </div>
                        <div class="swatch" data-grad="linear-gradient(135deg,#8b5cf6,#ec4899)"
                             onclick="pickColor(this)" style="background:linear-gradient(135deg,#8b5cf6,#ec4899)">
                            <div class="check-ic"><i class="fa-solid fa-check"></i></div>
                        </div>
                        <div class="swatch" data-grad="linear-gradient(135deg,#f43f5e,#f97316)"
                             onclick="pickColor(this)" style="background:linear-gradient(135deg,#f43f5e,#f97316)">
                            <div class="check-ic"><i class="fa-solid fa-check"></i></div>
                        </div>
                        <div class="swatch" data-grad="linear-gradient(135deg,#06b6d4,#6366f1)"
                             onclick="pickColor(this)" style="background:linear-gradient(135deg,#06b6d4,#6366f1)">
                            <div class="check-ic"><i class="fa-solid fa-check"></i></div>
                        </div>
                    </div>
                    <div class="fi-help" style="margin-top:8px;">Visual only — not saved to database</div>
                </div>
            </div>

            <!-- Status card -->
            <div class="panel-card">
                <div class="pc-head"><div class="pc-title">Publish Status</div></div>
                <div class="pc-body" style="padding-top:10px;">
                    <div class="sw-row @(Model.CategoryStatus ? "on" : "off")" id="swRowPanel">
                        <div class="sw-info">
                            <div class="swn" id="swLabelPanel" style="color:@(Model.CategoryStatus ? "#10b981" : "#94a3b8");">
                                @(Model.CategoryStatus ? "Active" : "Passive")
                            </div>
                            <div class="sws" id="swDescPanel">
                                @(Model.CategoryStatus ? "Visible in listings" : "Hidden from listings")
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tips -->
            <div class="tips-card">
                <div class="tips-head">
                    <i class="fa-solid fa-lightbulb" style="color:#fbbf24;"></i>
                    <div class="tips-title">Update Tips</div>
                </div>
                <div class="tips-body">
                    <div class="tip-row">
                        <i class="fa-solid fa-circle-dot tip-ic"></i>
                        <span>Category name changes affect all linked tours immediately.</span>
                    </div>
                    <div class="tip-row">
                        <i class="fa-solid fa-circle-dot tip-ic"></i>
                        <span>Setting Passive hides the category without deleting it.</span>
                    </div>
                    <div class="tip-row">
                        <i class="fa-solid fa-circle-dot tip-ic"></i>
                        <span>Keep names short, descriptive and consistent.</span>
                    </div>
                </div>
            </div>

        </div>

    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        /* ── Originals ───────────────────────────────────────────── */
        const origName   = "@Model.CategoryName";
        const origStatus = @(Model.CategoryStatus ? "true" : "false");
        const changed    = new Set();

        const LABELS = { CategoryName: 'Category Name', CategoryStatus: 'Status' };

        /* ── Track change ────────────────────────────────────────── */
        function trackChange(el, key) {
            const orig = el.dataset.original ?? '';
            const dot  = document.getElementById('dot-' + key);
            if (el.value !== orig) {
                changed.add(key);
                el.classList.add('changed');
                if (dot) dot.classList.add('show');
            } else {
                changed.delete(key);
                el.classList.remove('changed');
                if (dot) dot.classList.remove('show');
            }
            if (key === 'CategoryName') updateCC(el.value.length);
            renderDiff();
        }

        /* ── Char counter ────────────────────────────────────────── */
        function updateCC(n) {
            const el = document.getElementById('nameCount');
            el.textContent = n + ' / 60';
            el.className = 'char-count' + (n > 50 ? ' warn' : '') + (n >= 60 ? ' over' : '');
        }

        /* ── Live preview ────────────────────────────────────────── */
        function updatePreview() {
            const val     = document.getElementById('CategoryName').value.trim();
            const prevName = document.getElementById('prevName');
            const prevInit = document.getElementById('prevInitial');

            if (val) {
                prevName.textContent = val;
                prevName.classList.remove('placeholder');
                prevInit.textContent = val[0].toUpperCase();
            } else {
                prevName.textContent = 'Enter a name below...';
                prevName.classList.add('placeholder');
                prevInit.textContent = '?';
            }
        }

        /* ── Status sync ─────────────────────────────────────────── */
        function syncStatus(cb) {
            const row   = document.getElementById('swRow');
            const lbl   = document.getElementById('swLabel');
            const desc  = document.getElementById('swDesc');
            const panelRow = document.getElementById('swRowPanel');
            const panelLbl = document.getElementById('swLabelPanel');
            const panelDesc= document.getElementById('swDescPanel');

            if (cb.checked) {
                lbl.textContent = 'Active'; lbl.style.color = '#10b981';
                desc.textContent = 'Category is publicly visible';
                row.className = 'sw-row on';
                panelRow.className = 'sw-row on';
                panelLbl.textContent = 'Active'; panelLbl.style.color = '#10b981';
                panelDesc.textContent = 'Visible in listings';
            } else {
                lbl.textContent = 'Passive'; lbl.style.color = '#94a3b8';
                desc.textContent = "Category won't be visible";
                row.className = 'sw-row off';
                panelRow.className = 'sw-row off';
                panelLbl.textContent = 'Passive'; panelLbl.style.color = '#94a3b8';
                panelDesc.textContent = 'Hidden from listings';
            }

            if (cb.checked !== origStatus) changed.add('CategoryStatus');
            else changed.delete('CategoryStatus');
            renderDiff();
        }

        /* ── Color picker ────────────────────────────────────────── */
        function pickColor(el) {
            document.querySelectorAll('.swatch').forEach(s => s.classList.remove('selected'));
            el.classList.add('selected');
            const grad = el.dataset.grad;
            document.getElementById('prevAvatar').style.background = grad;
            document.getElementById('selectedColor').value = grad;
        }

        /* ── Diff render ─────────────────────────────────────────── */
        function renderDiff() {
            const list  = document.getElementById('diffList');
            const empty = document.getElementById('diffEmpty');
            const badge = document.getElementById('diffBadge');
            const cc    = document.getElementById('changeCount');

            list.querySelectorAll('.diff-item').forEach(e => e.remove());

            if (changed.size === 0) {
                empty.style.display = 'block';
                badge.style.display = 'none';
                cc.style.display    = 'none';
                return;
            }
            empty.style.display = 'none';
            badge.style.display = 'block';
            badge.textContent   = changed.size;
            cc.style.display    = 'inline-flex';
            cc.textContent      = changed.size + (changed.size === 1 ? ' change' : ' changes');

            changed.forEach(key => {
                const d = document.createElement('div');
                d.className = 'diff-item';
                d.innerHTML = `<div class="diff-dot"></div><div class="diff-name">${LABELS[key] || key}</div>`;
                list.appendChild(d);
            });
        }

        /* ── Submit ──────────────────────────────────────────────── */
        document.getElementById('ucForm').addEventListener('submit', () => {
            const btn = document.getElementById('saveBtn');
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Saving...';
            btn.disabled = true;
        });

        /* ── Init ────────────────────────────────────────────────── */
        updateCC(document.getElementById('CategoryName').value.length);
    </script>
}
