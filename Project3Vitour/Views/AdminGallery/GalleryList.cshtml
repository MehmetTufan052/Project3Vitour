@model IEnumerable<Project3Vitour.Dtos.GalleryDto.ResultGalleryDto>
@{
    ViewData["Title"] = "Galeri";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <style>
        .s-ico.violet {
            background: rgba(139,92,246,.14);
            color: #8b5cf6;
        }

        .s-ico.blue {
            background: rgba(59,130,246,.14);
            color: #3b82f6;
        }

        .s-ico.green {
            background: rgba(16,185,129,.14);
            color: #10b981;
        }

        .gl-thumb {
            width: 64px;
            height: 46px;
            border-radius: 8px;
            object-fit: cover;
            background: #f1f5f9;
            display: block;
            border: 1px solid #e2e8f0;
            transition: transform .2s,box-shadow .2s;
            cursor: zoom-in;
            flex-shrink: 0;
        }

            .gl-thumb:hover {
                transform: scale(1.08);
                box-shadow: 0 4px 14px rgba(0,0,0,.15);
                z-index: 5;
                position: relative;
            }

        .gl-chip {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: 11.5px;
            font-weight: 700;
            padding: 3px 10px;
            border-radius: 20px;
            background: #f5f3ff;
            color: #6d28d9;
            border: 1px solid #ddd6fe;
            max-width: 200px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .gl-chip-dot {
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: #8b5cf6;
            flex-shrink: 0;
        }

        .gl-id {
            font-family: 'DM Mono',monospace;
            font-size: 11px;
            color: #94a3b8;
            font-weight: 500;
        }

        .gl-url {
            display: flex;
            align-items: center;
            gap: 7px;
            max-width: 240px;
        }

        .gl-url-text {
            font-size: 12px;
            color: #475569;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            flex: 1;
        }

        .gl-url-link {
            width: 24px;
            height: 24px;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            background: #f1f5f9;
            color: #64748b;
            border: 1px solid #e2e8f0;
            flex-shrink: 0;
            transition: all .15s;
            text-decoration: none;
        }

            .gl-url-link:hover {
                background: #eff6ff;
                color: #2563eb;
                border-color: #bfdbfe;
            }

        .gl-lb {
            position: fixed;
            inset: 0;
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
            opacity: 0;
            pointer-events: none;
            transition: opacity .25s;
        }

            .gl-lb.open {
                opacity: 1;
                pointer-events: all;
            }

        .gl-lb-bg {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,.82);
            backdrop-filter: blur(18px);
            cursor: pointer;
        }

        .gl-lb-box {
            position: relative;
            z-index: 1;
            max-width: min(860px,88vw);
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 32px 80px rgba(0,0,0,.5);
            transform: scale(.92);
            transition: transform .3s cubic-bezier(.34,1.56,.64,1);
        }

        .gl-lb.open .gl-lb-box {
            transform: scale(1);
        }

        .gl-lb-box img {
            display: block;
            max-width: 100%;
            max-height: calc(88vh - 64px);
            object-fit: contain;
            background: #0f172a;
        }

        .gl-lb-footer {
            background: rgba(15,23,42,.95);
            backdrop-filter: blur(12px);
            padding: 12px 18px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
        }

        .gl-lb-tour {
            font-size: 12.5px;
            font-weight: 700;
            color: #e2e8f0;
            display: flex;
            align-items: center;
            gap: 7px;
        }

            .gl-lb-tour i {
                color: #818cf8;
            }

        .gl-lb-close {
            width: 30px;
            height: 30px;
            border-radius: 8px;
            background: rgba(255,255,255,.1);
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            color: #e2e8f0;
            cursor: pointer;
            transition: background .15s;
        }

            .gl-lb-close:hover {
                background: rgba(244,63,94,.3);
                color: #fda4af;
            }

        .gl-lb-nav {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background: rgba(255,255,255,.12);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255,255,255,.15);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            color: #fff;
            cursor: pointer;
            transition: all .2s;
            z-index: 2;
        }

            .gl-lb-nav:hover {
                background: rgba(255,255,255,.22);
            }

            .gl-lb-nav.prev {
                left: -52px;
            }

            .gl-lb-nav.next {
                right: -52px;
            }

        .gl-del-ov {
            position: fixed;
            inset: 0;
            z-index: 800;
            background: rgba(10,14,26,.55);
            backdrop-filter: blur(8px);
            display: none;
            align-items: center;
            justify-content: center;
            padding: 16px;
        }

            .gl-del-ov.open {
                display: flex;
            }

        .gl-del-box {
            background: #fff;
            border-radius: 18px;
            width: 100%;
            max-width: 390px;
            padding: 28px 28px 24px;
            text-align: center;
            box-shadow: 0 24px 60px rgba(0,0,0,.20);
        }

        .gl-del-ic {
            width: 52px;
            height: 52px;
            background: #fee2e2;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            color: #dc2626;
            margin: 0 auto 14px;
        }

        .gl-del-title {
            font-size: 15px;
            font-weight: 800;
            color: #0f172a;
            margin-bottom: 6px;
        }

        .gl-del-desc {
            font-size: 12.5px;
            color: #475569;
            line-height: 1.55;
        }

        .gl-del-acts {
            display: flex;
            gap: 10px;
            justify-content: center;
            margin-top: 20px;
        }

        .dtbl tbody tr {
            animation: fadeUp .22s both;
        }

            .dtbl tbody tr:nth-child(1) {
                animation-delay: .03s
            }

            .dtbl tbody tr:nth-child(2) {
                animation-delay: .06s
            }

            .dtbl tbody tr:nth-child(3) {
                animation-delay: .09s
            }

            .dtbl tbody tr:nth-child(4) {
                animation-delay: .12s
            }

            .dtbl tbody tr:nth-child(5) {
                animation-delay: .15s
            }

            .dtbl tbody tr:nth-child(6) {
                animation-delay: .18s
            }

            .dtbl tbody tr:nth-child(7) {
                animation-delay: .21s
            }

            .dtbl tbody tr:nth-child(8) {
                animation-delay: .24s
            }
    </style>
}

@{
    var safeModel = Model ?? Enumerable.Empty<Project3Vitour.Dtos.GalleryDto.ResultGalleryDto>();
    int glTotal = safeModel.Count();
    int glGroups = safeModel.GroupBy(g => g.TourName).Count();
    int glAvg = glGroups > 0 ? glTotal / glGroups : 0;
    var glTours = safeModel.Select(g => g.TourName).Distinct().OrderBy(t => t).ToList();
}

<div class="ph anim">
    <div>
        <div class="ph-eye">Collections</div>
        <h1 class="ph-h1">Galeri Yönetimi</h1>
        <p class="ph-desc">Tur fotoğraflarını görüntüleyin, düzenleyin ve yönetin.</p>
    </div>
    <div class="ph-acts">
        <a href="@Url.Action("CreateGallery", "AdminGallery")" class="btn btn-primary">
            <i class="fa-solid fa-plus"></i> Görsel Ekle
        </a>
    </div>
</div>

<div class="s-grid cols3 anim">
    <div class="s-card">
        <div class="s-ico violet"><i class="fa-solid fa-images"></i></div>
        <div>
            <div class="s-lbl">Toplam Görsel</div>
            <div class="s-val">@glTotal</div>
            <div class="s-delta">Galerindeki tüm görseller</div>
        </div>
    </div>
    <div class="s-card">
        <div class="s-ico blue"><i class="fa-solid fa-map-location-dot"></i></div>
        <div>
            <div class="s-lbl">Kapsanan Tur</div>
            <div class="s-val">@glGroups</div>
            <div class="s-delta">Farklı tur sayısı</div>
        </div>
    </div>
    <div class="s-card">
        <div class="s-ico green"><i class="fa-solid fa-layer-group"></i></div>
        <div>
            <div class="s-lbl">Tur Başına Ort.</div>
            <div class="s-val">@glAvg</div>
            <div class="s-delta">Ortalama görsel / tur</div>
        </div>
    </div>
</div>

<div class="card anim">
    <div class="c-head">
        <div>
            <div class="c-title">Görsel Listesi</div>
            <div class="c-sub">Tüm galeri görselleri — arama ve tur filtresi ile yönetin.</div>
        </div>
    </div>

    <div class="f-bar">
        <div class="fi">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" class="f-input" id="glSearch"
                   placeholder="Tur adı veya ID ara…" style="min-width:220px;" />
        </div>
        <div class="fi">
            <i class="fa-solid fa-map-location-dot"></i>
            <select class="f-sel" id="glTourFilter" style="min-width:170px;">
                <option value="">Tüm Turlar</option>
                @foreach (var t in glTours)
                {
                    <option value="@t">@t</option>
                }
            </select>
        </div>
        <span class="f-count">
            Toplam <strong id="glVisibleCount">@glTotal</strong> görsel
        </span>
    </div>

    <div style="overflow-x:auto;">
        @if (!safeModel.Any())
        {
            <div class="empty">
                <div class="empty-ic"><i class="fa-regular fa-images"></i></div>
                <h3>Henüz görsel yok</h3>
                <p>İlk görseli ekleyerek galeriyi oluşturun.</p>
            </div>
        }
        else
        {
            <table class="dtbl">
                <thead>
                    <tr>
                        <th style="width:40px;">#</th>
                        <th style="width:84px;">Önizleme</th>
                        <th>Tur</th>
                        <th>Görsel URL</th>
                        <th>ID</th>
                        <th style="text-align:center;width:110px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody id="glBody">
                    @{
                        int glRow = 0;
                        foreach (var img in safeModel)
                        {
                            glRow++;
                            string glShortId = img.GalleryId != null && img.GalleryId.Length > 10 ? img.GalleryId.Substring(0, 10) + "…" : (img.GalleryId ?? "");
                            string glShortUrl = img.ImageUrl != null && img.ImageUrl.Length > 46 ? img.ImageUrl.Substring(0, 46) + "…" : (img.ImageUrl ?? "");
                            string glSafeTour = (img.TourName ?? "").Replace("'", "\\'");
                            string glSafeId = (img.GalleryId ?? "");
                            <tr data-tour="@((img.TourName ?? "").ToLower())" data-id="@((img.GalleryId ?? "").ToLower())" data-filtered="false">
                                <td><span style="font-size:11.5px;font-weight:700;color:#94a3b8;font-family:'DM Mono',monospace;">@glRow</span></td>
                                <td>
                                    <img class="gl-thumb"
                                         src="@img.ImageUrl"
                                         alt="@img.TourName"
                                         loading="lazy"
                                         data-url="@img.ImageUrl"
                                         data-tour="@img.TourName"
                                         onclick="openLbDirect(this.getAttribute('data-url'), this.getAttribute('data-tour'))"
                                         onerror="this.src='';this.style.background='#f1f5f9';" />
                                </td>
                                <td>
                                    <span class="gl-chip">
                                        <span class="gl-chip-dot"></span>
                                        @img.TourName
                                    </span>
                                </td>
                                <td>
                                    <div class="gl-url">
                                        <span class="gl-url-text" title="@img.ImageUrl">@glShortUrl</span>
                                        <a href="@img.ImageUrl" target="_blank" class="gl-url-link" title="Yeni sekmede aç">
                                            <i class="fa-solid fa-arrow-up-right-from-square"></i>
                                        </a>
                                    </div>
                                </td>
                                <td><span class="gl-id" title="@img.GalleryId">@glShortId</span></td>
                                <td>
                                    <div class="acts" style="justify-content:center;">
                                        <button type="button" class="abt v" title="Önizle"
                                                onclick="openLbDirect(this.closest('tr').querySelector('.gl-thumb').getAttribute('data-url'), this.closest('tr').querySelector('.gl-thumb').getAttribute('data-tour'))">
                                            <i class="fa-solid fa-eye"></i>
                                        </button>
                                        <a href="@Url.Action("UpdateGallery", "AdminGallery", new { id = img.GalleryId })" class="abt e" title="Düzenle">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </a>
                                        <button type="button" class="abt d" title="Sil"
                                                data-del-id="@glSafeId"
                                                data-del-tour="@img.TourName"
                                                onclick="openDelModal(this.getAttribute('data-del-id'), this.getAttribute('data-del-tour'))">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>

            <div class="empty" id="glEmpty" style="display:none;">
                <div class="empty-ic"><i class="fa-solid fa-filter-circle-xmark"></i></div>
                <h3>Sonuç Bulunamadı</h3>
                <p>Arama kriterlerinizle eşleşen görsel yok.</p>
            </div>
        }
    </div>

    <div class="c-foot">
        <div style="font-size:12px;color:var(--text-muted);">
            Gösterilen: <strong style="color:var(--text-secondary);" id="glPageInfo">—</strong>
        </div>
        <div class="pag" style="padding:0;">
            <button class="pg" id="glPrev" onclick="glChangePage(-1)" disabled>
                <i class="fa-solid fa-chevron-left" style="font-size:10px;"></i>
            </button>
            <button class="pg on" id="glP1" onclick="glGoPage(1)">1</button>
            <button class="pg" id="glP2" onclick="glGoPage(2)">2</button>
            <button class="pg" id="glP3" onclick="glGoPage(3)">3</button>
            <button class="pg" id="glNext" onclick="glChangePage(1)">
                <i class="fa-solid fa-chevron-right" style="font-size:10px;"></i>
            </button>
        </div>
    </div>
</div>

<div class="gl-lb" id="glLb">
    <div class="gl-lb-bg" onclick="closeLb()"></div>
    <button class="gl-lb-nav prev" onclick="lbNav(-1)"><i class="fa-solid fa-chevron-left"></i></button>
    <div class="gl-lb-box">
        <img id="glLbImg" src="" alt="Önizleme" />
        <div class="gl-lb-footer">
            <div class="gl-lb-tour">
                <i class="fa-solid fa-map-location-dot"></i>
                <span id="glLbTour">—</span>
            </div>
            <button class="gl-lb-close" onclick="closeLb()"><i class="fa-solid fa-xmark"></i></button>
        </div>
    </div>
    <button class="gl-lb-nav next" onclick="lbNav(1)"><i class="fa-solid fa-chevron-right"></i></button>
</div>

<div class="gl-del-ov" id="glDelOv">
    <div class="gl-del-box">
        <div class="gl-del-ic"><i class="fa-solid fa-triangle-exclamation"></i></div>
        <div class="gl-del-title">Görseli Sil?</div>
        <div class="gl-del-desc" id="glDelDesc">Bu görsel kalıcı olarak silinecek.</div>
        <div class="gl-del-acts">
            <button type="button" class="btn btn-ghost" onclick="closeDelModal()">
                <i class="fa-solid fa-xmark"></i> İptal
            </button>
            <a id="glDelConfirm" href="#" class="btn"
               style="background:linear-gradient(135deg,#f43f5e,#e11d48);color:#fff;box-shadow:0 2px 14px rgba(244,63,94,.35);">
                <i class="fa-solid fa-trash"></i> Evet, Sil
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var _lbUrls  = [];
        var _lbNames = [];
        var _lbCur   = 0;
        var glCurPage  = 1;
        var glPageSize = 10;

        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.gl-thumb[data-url]').forEach(function (t) {
                _lbUrls.push(t.getAttribute('data-url') || '');
                _lbNames.push(t.getAttribute('data-tour') || '');
            });
            glRenderPage();
        });

        function openLbDirect(url, tour) {
            var idx = _lbUrls.indexOf(url);
            _lbCur = idx >= 0 ? idx : 0;
            document.getElementById('glLbImg').src = url;
            document.getElementById('glLbTour').textContent = tour || '—';
            document.getElementById('glLb').classList.add('open');
            document.body.style.overflow = 'hidden';
        }

        function closeLb() {
            document.getElementById('glLb').classList.remove('open');
            document.body.style.overflow = '';
            setTimeout(function () { document.getElementById('glLbImg').src = ''; }, 280);
        }

        function lbNav(dir) {
            _lbCur = (_lbCur + dir + _lbUrls.length) % _lbUrls.length;
            openLbDirect(_lbUrls[_lbCur], _lbNames[_lbCur]);
        }

        document.addEventListener('keydown', function (e) {
            if (!document.getElementById('glLb').classList.contains('open')) return;
            if (e.key === 'Escape') closeLb();
            if (e.key === 'ArrowRight') lbNav(1);
            if (e.key === 'ArrowLeft')  lbNav(-1);
        });

        function openDelModal(id, tour) {
            document.getElementById('glDelDesc').innerHTML =
                '<strong>' + escH(tour) + '</strong> turuna ait bu görsel kalıcı olarak silinecek.';
            document.getElementById('glDelConfirm').href = '/AdminGallery/DeleteGallery/' + id;
            document.getElementById('glDelOv').classList.add('open');
        }

        function closeDelModal() {
            document.getElementById('glDelOv').classList.remove('open');
        }

        document.getElementById('glDelOv').addEventListener('click', function (e) {
            if (e.target === this) closeDelModal();
        });

        function escH(s) {
            return String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        }

        function applyGlFilter() {
            var q    = (document.getElementById('glSearch').value || '').toLowerCase().trim();
            var tour = (document.getElementById('glTourFilter').value || '').toLowerCase();
            var rows = Array.from(document.querySelectorAll('#glBody tr'));
            var n    = 0;

            rows.forEach(function (row) {
                var rTour = (row.dataset.tour || '');
                var rId   = (row.dataset.id   || '');
                var show  = (!q    || rTour.includes(q) || rId.includes(q))
                         && (!tour || rTour === tour);
                row.dataset.filtered = show ? 'false' : 'true';
                if (show) n++;
            });

            document.getElementById('glVisibleCount').textContent = n;
            var el = document.getElementById('glEmpty');
            if (el) el.style.display = n === 0 ? 'flex' : 'none';
            glCurPage = 1;
            glRenderPage();
        }

        document.getElementById('glSearch').addEventListener('input', applyGlFilter);
        document.getElementById('glTourFilter').addEventListener('change', applyGlFilter);

        function getGlVisible() {
            return Array.from(document.querySelectorAll('#glBody tr'))
                       .filter(function (r) { return r.dataset.filtered !== 'true'; });
        }

        function glRenderPage() {
            var vis   = getGlVisible();
            var tot   = vis.length;
            var pages = Math.max(1, Math.ceil(tot / glPageSize));
            glCurPage = Math.min(Math.max(1, glCurPage), pages);
            var start = (glCurPage - 1) * glPageSize;
            var end   = start + glPageSize;

            Array.from(document.querySelectorAll('#glBody tr')).forEach(function (r) {
                if (r.dataset.filtered === 'true') { r.style.display = 'none'; return; }
                r.style.display = 'none';
            });
            vis.forEach(function (r, i) {
                r.style.display = (i >= start && i < end) ? '' : 'none';
            });

            document.getElementById('glPrev').disabled = glCurPage <= 1;
            document.getElementById('glNext').disabled = glCurPage >= pages;
            document.getElementById('glPageInfo').textContent =
                tot === 0 ? '0 / 0' : (start + 1) + '–' + Math.min(end, tot) + ' / ' + tot;

            ['glP1', 'glP2', 'glP3'].forEach(function (id, i) {
                var btn = document.getElementById(id);
                if (!btn) return;
                btn.classList.toggle('on', glCurPage === i + 1);
                btn.style.display = (i + 1 <= pages) ? '' : 'none';
            });
        }

        function glChangePage(dir) { glCurPage += dir; glRenderPage(); }
        function glGoPage(p)        { glCurPage = p;   glRenderPage(); }
    </script>
}
