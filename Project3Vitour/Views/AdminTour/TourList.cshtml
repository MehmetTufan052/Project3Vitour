@model List<ResultTourDto>
@{
    ViewData["Title"] = "TourIndex";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var tourList = Model?.ToList() ?? new List<Project3Vitour.Dtos.TourDtos.ResultTourDto>();
    var total = tourList.Count;
    var active = tourList.Count(t => t.IsStatus);
    var passive = tourList.Count(t => !t.IsStatus);
    var avgPrice = total > 0 ? tourList.Average(t => (double)t.Price) : 0;

    // Badge dot colors
    var badgeColors = new Dictionary<string, (string bg, string color, string border)>
    {
        { "Fırsat",     ("#fef3c7", "#b45309", "#fde68a") },
        { "Öne Çıkan",  ("#dbeafe", "#1d4ed8", "#bfdbfe") },
        { "Yeni",       ("#dcfce7", "#15803d", "#bbf7d0") },
    };

    // Avatar gradient pool
    var gradients = new[]
    {
        "linear-gradient(135deg,#3b82f6,#6366f1)",
        "linear-gradient(135deg,#10b981,#06b6d4)",
        "linear-gradient(135deg,#f59e0b,#ef4444)",
        "linear-gradient(135deg,#8b5cf6,#ec4899)",
        "linear-gradient(135deg,#06b6d4,#3b82f6)",
    };
}

<!-- Page Header -->
<div class="ph anim">
    <div>
        <div class="ph-eye">Management</div>
        <h1 class="ph-h1">Tours</h1>
        <p class="ph-desc">Manage all tour packages</p>
    </div>
    <div class="ph-acts">
        <a href="/AdminTour/CreateTour" class="btn btn-primary">
            <i class="fa-solid fa-plus"></i> Yeni Tur Ekle
        </a>
    </div>
</div>

<!-- Stat Cards -->
<div class="s-grid">
    <div class="s-card">
        <div class="s-ico" style="background:#eff6ff;color:#3b82f6;">
            <i class="fa-solid fa-map-location-dot"></i>
        </div>
        <div>
            <div class="s-lbl">Toplam Tur Sayısı</div>
            <div class="s-val">@total</div>
        </div>
    </div>
    <div class="s-card">
        <div class="s-ico" style="background:#f0fdf4;color:#10b981;">
            <i class="fa-solid fa-circle-check"></i>
        </div>
        <div>
            <div class="s-lbl">Aktif Turlar</div>
            <div class="s-val">@active</div>
        </div>
    </div>
    <div class="s-card">
        <div class="s-ico" style="background:#fff7ed;color:#f59e0b;">
            <i class="fa-solid fa-pause-circle"></i>
        </div>
        <div>
            <div class="s-lbl">Pasif Turlar</div>
            <div class="s-val">@passive</div>
        </div>
    </div>
    <div class="s-card">
        <div class="s-ico" style="background:#fdf4ff;color:#a855f7;">
            <i class="fa-solid fa-dollar-sign"></i>
        </div>
        <div>
            <div class="s-lbl">Ortalam Tur Fiyatları</div>
            <div class="s-val">@avgPrice.ToString("N0") ₺</div>
        </div>
    </div>
</div>

<!-- Table Card -->
<div class="card anim">

    <!-- Filter Bar -->
    <div class="f-bar">
        <div class="fi">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" class="f-input" id="searchInput" placeholder="Search tours...">
        </div>
        <select class="f-sel" id="statusFilter">
            <option value="">All Status</option>
            <option value="active">Active</option>
            <option value="passive">Passive</option>
        </select>
        <select class="f-sel" id="badgeFilter">
            <option value="">All Badges</option>
            <option value="Fırsat">Fırsat</option>
            <option value="Öne Çıkan">Öne Çıkan</option>
            <option value="Yeni">Yeni</option>
        </select>
        <span class="f-count">Showing <strong id="showCount">@total</strong> of <strong>@total</strong> tours</span>
    </div>

    <!-- Table -->
    <table class="dtbl" id="toursTable">
        <thead>
            <tr>
                <th>Tour</th>
                <th>Badge</th>
                <th>Duration</th>
                <th>Capacity</th>
                <th>Price</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody id="toursBody">
            @if (!tourList.Any())
            {
                <tr>
                    <td colspan="7">
                        <div class="empty">
                            <div class="empty-ic"><i class="fa-solid fa-map-location-dot"></i></div>
                            <h3>No tours yet</h3>
                            <p>Add your first tour to get started.</p>
                        </div>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var (tour, i) in tourList.Select((t, i) => (t, i)))
                {
                    var grad = gradients[i % gradients.Length];
                    var initials = tour.Title?.Length > 0
                    ? tour.Title.Split(' ').Take(2).Select(w => w[0].ToString().ToUpper()).Aggregate((a, b) => a + b)
                    : "?";

                    // Badge style
                    (string bg, string clr, string brd) bStyle = badgeColors.TryGetValue(tour.Badge ?? "", out var bs)
                    ? bs : ("#f1f5f9", "#64748b", "#e2e8f0");

                    <tr data-status="@(tour.IsStatus ? "active" : "passive")"
                        data-badge="@(tour.Badge ?? "")"
                        data-title="@(tour.Title?.ToLower() ?? "")">
                        <td>
                            <div style="display:flex;align-items:center;gap:11px;">
                                @if (!string.IsNullOrEmpty(tour.CoverImageUrl))
                                {
                                    <img src="@tour.CoverImageUrl" alt="@tour.Title"
                                         style="width:38px;height:38px;border-radius:9px;object-fit:cover;flex-shrink:0;box-shadow:0 2px 6px rgba(0,0,0,0.12);" />
                                }
                                else
                                {
                                    <div class="av" style="background:@grad;">@initials</div>
                                }
                                <div>
                                    <div style="font-weight:700;font-size:13px;color:#0f172a;line-height:1.2;">@tour.Title</div>
                                    <div style="font-size:11px;color:#94a3b8;margin-top:2px;max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                        @(tour.Description?.Length > 50 ? tour.Description[..50] + "…" : tour.Description)
                                    </div>
                                </div>
                            </div>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(tour.Badge))
                            {
                                <span class="badge"
                                      style="background:@bStyle.bg;color:@bStyle.clr;border:1px solid @bStyle.brd;">
                                    @tour.Badge
                                </span>
                            }
                            else
                            {
                                <span style="color:#cbd5e1;font-size:12px;">—</span>
                            }
                        </td>
                        <td>
                            <span style="display:inline-flex;align-items:center;gap:5px;font-size:13px;color:#475569;">
                                <i class="fa-regular fa-calendar" style="color:#94a3b8;font-size:12px;"></i>
                                @tour.DayCount Days
                            </span>
                        </td>
                        <td>
                            <span style="display:inline-flex;align-items:center;gap:5px;font-size:13px;color:#475569;">
                                <i class="fa-solid fa-users" style="color:#94a3b8;font-size:11px;"></i>
                                @tour.Capacity
                            </span>
                        </td>
                        <td>
                            <span style="font-weight:700;font-size:13.5px;color:#0f172a;">
                                @tour.Price.ToString("N0") ₺
                            </span>
                        </td>
                        <td>
                            @if (tour.IsStatus)
                            {
                                <span class="badge b-green"><span class="bd"></span>Active</span>
                            }
                            else
                            {
                                <span class="badge b-gray"><span class="bd"></span>Passive</span>
                            }
                        </td>
                        <td>
                            <div class="acts">
                                <a href="/AdminTour/Details/@tour.TourId" class="abt v" title="Details">
                                    <i class="fa-solid fa-eye"></i>
                                </a>
                                <a href="/AdminTour/UpdateTour/@tour.TourId" class="abt e" title="Edit">
                                    <i class="fa-solid fa-pen"></i>
                                </a>
                                <a href="/AdminTour/Delete/@tour.TourId"
                                   class="abt d" title="Delete"
                                   onclick="return confirm('Bu turu silmek istediğinize emin misiniz?')">
                                    <i class="fa-solid fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>

</div>

@section Scripts {
    <script>
        const searchInput  = document.getElementById('searchInput');
        const statusFilter = document.getElementById('statusFilter');
        const badgeFilter  = document.getElementById('badgeFilter');
        const showCount    = document.getElementById('showCount');
        const rows         = document.querySelectorAll('#toursBody tr[data-title]');

        function applyFilters() {
            const q      = searchInput.value.toLowerCase().trim();
            const status = statusFilter.value;
            const badge  = badgeFilter.value;
            let visible  = 0;

            rows.forEach(row => {
                const matchTitle  = !q      || row.dataset.title.includes(q);
                const matchStatus = !status || row.dataset.status === status;
                const matchBadge  = !badge  || row.dataset.badge  === badge;
                const show = matchTitle && matchStatus && matchBadge;
                row.style.display = show ? '' : 'none';
                if (show) visible++;
            });

            showCount.textContent = visible;
        }

        searchInput.addEventListener('input',  applyFilters);
        statusFilter.addEventListener('change', applyFilters);
        badgeFilter.addEventListener('change',  applyFilters);
    </script>
}
