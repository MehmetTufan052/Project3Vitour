<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Yorum Yönetimi — Admin Panel</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;0,9..40,800;1,9..40,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        /* ══════════════════════════════════════════
           ROOT TOKENS
        ══════════════════════════════════════════ */
        :root {
            --bg-base: #eef2f9;
            --glass: rgba(255,255,255,0.62);
            --glass-edge: rgba(255,255,255,0.85);
            --glass-inner: rgba(255,255,255,0.45);
            --border-g: rgba(255,255,255,0.75);
            --border-s: rgba(180,195,230,0.40);
            --text: #0f1729;
            --text-2: #3d4f6e;
            --muted: #7b90b8;
            --accent: #4f6ef7;
            --accent-lt: rgba(79,110,247,0.12);
            --accent-glow: rgba(79,110,247,0.22);
            --green: #10b981;
            --red: #ef4444;
            --amber: #f59e0b;
            --slate: #64748b;
            --radius: 18px;
            --radius-md: 12px;
            --radius-sm: 8px;
            --shadow-sm: 0 2px 8px rgba(80,100,160,0.08), 0 1px 2px rgba(80,100,160,0.06);
            --shadow-md: 0 8px 28px rgba(80,100,160,0.13), 0 2px 6px rgba(80,100,160,0.07);
            --shadow-lg: 0 20px 60px rgba(60,80,160,0.16), 0 4px 12px rgba(60,80,160,0.08);
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg-base);
            color: var(--text);
            min-height: 100vh;
            font-size: 14px;
            overflow-x: hidden;
        }

            body::before {
                content: '';
                position: fixed;
                inset: 0;
                z-index: -1;
                pointer-events: none;
                background: radial-gradient(ellipse 70% 50% at 15% 15%, #c7d9ff 0%, transparent 70%), radial-gradient(ellipse 55% 45% at 85% 10%, #ddd6fe 0%, transparent 65%), radial-gradient(ellipse 60% 50% at 70% 85%, #bfecda 0%, transparent 65%), radial-gradient(ellipse 40% 40% at 10% 80%, rgba(199,217,255,0.5) 0%, transparent 60%);
            }

        /* ══════════════════════════════════════════
           SIDEBAR
        ══════════════════════════════════════════ */
        .sidebar {
            width: 252px;
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            display: flex;
            flex-direction: column;
            z-index: 200;
            background: rgba(255,255,255,0.75);
            backdrop-filter: blur(28px) saturate(1.8);
            -webkit-backdrop-filter: blur(28px) saturate(1.8);
            border-right: 1px solid var(--border-g);
            box-shadow: 4px 0 32px rgba(79,110,247,0.07), inset -1px 0 0 rgba(255,255,255,0.9);
            transition: transform .35s cubic-bezier(.4,0,.2,1);
        }

        .sidebar-logo {
            padding: 26px 20px 22px;
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid var(--border-s);
        }

        .logo-mark {
            width: 38px;
            height: 38px;
            border-radius: 12px;
            flex-shrink: 0;
            background: linear-gradient(135deg, #4f6ef7 0%, #818cf8 60%, #a78bfa 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            font-weight: 800;
            color: #fff;
            box-shadow: 0 4px 14px rgba(79,110,247,0.45);
        }

        .logo-text {
            font-weight: 800;
            font-size: 15px;
            color: var(--text);
            line-height: 1.2;
        }

            .logo-text span {
                display: block;
                font-size: 11px;
                color: var(--muted);
                font-weight: 400;
                margin-top: 1px;
            }

        .sidebar-nav {
            padding: 18px 12px;
            flex: 1;
            overflow-y: auto;
        }

        .nav-section {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: .1em;
            color: var(--muted);
            text-transform: uppercase;
            padding: 6px 10px 8px;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 14px;
            border-radius: var(--radius-md);
            color: var(--text-2);
            font-weight: 500;
            font-size: 13.5px;
            cursor: pointer;
            transition: all .18s;
            margin-bottom: 2px;
            text-decoration: none;
        }

            .nav-item i {
                font-size: 16px;
                flex-shrink: 0;
            }

            .nav-item:hover {
                background: rgba(79,110,247,0.07);
                color: var(--accent);
                transform: translateX(2px);
            }

            .nav-item.active {
                background: linear-gradient(90deg,rgba(79,110,247,0.15),rgba(79,110,247,0.05));
                color: var(--accent);
                box-shadow: inset 2px 0 0 var(--accent);
            }

        .sidebar-footer {
            padding: 16px 14px;
            border-top: 1px solid var(--border-s);
        }

        .user-card {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: var(--radius-md);
            background: rgba(79,110,247,0.07);
            border: 1px solid rgba(79,110,247,0.12);
            cursor: pointer;
            transition: all .18s;
        }

            .user-card:hover {
                background: rgba(79,110,247,0.12);
            }

        .user-avatar-sm {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            flex-shrink: 0;
            background: linear-gradient(135deg,#4f6ef7,#a78bfa);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 700;
            color: #fff;
            box-shadow: 0 2px 8px rgba(79,110,247,0.35);
        }

        .user-name {
            font-size: 13px;
            font-weight: 700;
            color: var(--text);
        }

        .user-role {
            font-size: 11px;
            color: var(--muted);
        }

        /* ══════════════════════════════════════════
           MAIN LAYOUT
        ══════════════════════════════════════════ */
        .main-wrap {
            margin-left: 252px;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* TOPBAR */
        .topbar {
            background: rgba(255,255,255,0.7);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border-g);
            box-shadow: 0 2px 16px rgba(79,110,247,0.06), inset 0 -1px 0 var(--border-s);
            padding: 0 28px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .breadcrumb-trail {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .bc-icon {
            width: 34px;
            height: 34px;
            background: var(--accent-lt);
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--accent);
            font-size: 15px;
        }

        .bc-title {
            font-size: 16px;
            font-weight: 800;
            color: var(--text);
        }

        .bc-sub {
            font-size: 12px;
            color: var(--muted);
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .btn-icon {
            width: 38px;
            height: 38px;
            border-radius: var(--radius-md);
            background: rgba(255,255,255,0.8);
            border: 1px solid var(--border-s);
            color: var(--text-2);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all .18s;
            font-size: 15px;
            box-shadow: var(--shadow-sm);
            position: relative;
        }

            .btn-icon:hover {
                background: white;
                border-color: var(--accent-glow);
                color: var(--accent);
                box-shadow: 0 4px 14px rgba(79,110,247,0.18);
                transform: translateY(-1px);
            }

        .notif-dot::after {
            content: '';
            position: absolute;
            top: 7px;
            right: 7px;
            width: 7px;
            height: 7px;
            background: var(--red);
            border-radius: 50%;
            border: 2px solid white;
        }

        .topbar-divider {
            width: 1px;
            height: 24px;
            background: var(--border-s);
            margin: 0 4px;
        }

        .topbar-date {
            font-size: 12px;
            color: var(--muted);
            font-weight: 500;
        }

        /* CONTENT */
        .main-content {
            padding: 28px 28px 40px;
            flex: 1;
        }

        /* PAGE HEADER */
        .page-header {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            margin-bottom: 28px;
            flex-wrap: wrap;
            gap: 12px;
        }

        .page-title {
            font-size: 26px;
            font-weight: 800;
            color: var(--text);
            letter-spacing: -.4px;
        }

            .page-title span {
                background: linear-gradient(90deg,#4f6ef7,#818cf8);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }

        .page-subtitle {
            font-size: 13.5px;
            color: var(--muted);
            margin-top: 3px;
        }

        /* ══════════════════════════════════════════
           STAT CARDS
        ══════════════════════════════════════════ */
        .stat-card {
            border-radius: var(--radius);
            padding: 24px 22px 20px;
            position: relative;
            overflow: hidden;
            transition: transform .22s cubic-bezier(.4,0,.2,1), box-shadow .22s;
            background: var(--glass);
            backdrop-filter: blur(20px) saturate(1.6);
            -webkit-backdrop-filter: blur(20px) saturate(1.6);
            border: 1px solid var(--border-g);
            box-shadow: var(--shadow-md), inset 0 1px 0 var(--glass-edge);
        }

            .stat-card::after {
                content: '';
                position: absolute;
                top: -40px;
                right: -30px;
                width: 120px;
                height: 120px;
                border-radius: 50%;
                background: var(--card-orb, rgba(79,110,247,0.1));
                pointer-events: none;
            }

            .stat-card:hover {
                transform: translateY(-5px);
                box-shadow: var(--shadow-lg), inset 0 1px 0 var(--glass-edge);
            }

        .stat-card-top {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: 18px;
        }

        .stat-icon {
            width: 46px;
            height: 46px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .stat-badge {
            font-size: 11px;
            font-weight: 700;
            padding: 3px 9px;
            border-radius: 20px;
        }

        .stat-number {
            font-size: 36px;
            font-weight: 800;
            line-height: 1;
            letter-spacing: -1px;
            margin-bottom: 4px;
        }

        .stat-label {
            font-size: 13px;
            color: var(--text-2);
            font-weight: 500;
        }

        .stat-bar-track {
            height: 4px;
            background: rgba(0,0,0,0.06);
            border-radius: 4px;
            overflow: hidden;
            margin-top: 16px;
        }

        .stat-bar-fill {
            height: 100%;
            border-radius: 4px;
            transition: width .8s cubic-bezier(.4,0,.2,1);
        }

        /* ══════════════════════════════════════════
           FILTER BAR
        ══════════════════════════════════════════ */
        .filter-bar {
            border-radius: var(--radius);
            padding: 14px 18px;
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            align-items: center;
            margin-bottom: 20px;
            background: var(--glass);
            backdrop-filter: blur(20px) saturate(1.6);
            -webkit-backdrop-filter: blur(20px) saturate(1.6);
            border: 1px solid var(--border-g);
            box-shadow: var(--shadow-sm), inset 0 1px 0 var(--glass-edge);
        }

        .search-wrap {
            position: relative;
            flex: 1;
            min-width: 200px;
        }

            .search-wrap i {
                position: absolute;
                left: 13px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--muted);
                font-size: 14px;
                pointer-events: none;
            }

        .form-control, .form-select {
            background: rgba(255,255,255,0.75) !important;
            border: 1px solid var(--border-s) !important;
            color: var(--text) !important;
            border-radius: var(--radius-sm) !important;
            font-family: 'DM Sans', sans-serif;
            font-size: 13.5px;
            padding: 9px 14px;
            transition: all .2s;
            box-shadow: var(--shadow-sm) !important;
        }

        .search-wrap .form-control {
            padding-left: 40px;
        }

        .form-control::placeholder {
            color: var(--muted);
        }

        .form-control:focus, .form-select:focus {
            background: white !important;
            border-color: rgba(79,110,247,0.5) !important;
            box-shadow: 0 0 0 3px var(--accent-glow), var(--shadow-sm) !important;
            outline: none;
        }

        .form-select option {
            background: white;
            color: var(--text);
        }

        /* ══════════════════════════════════════════
           TABLE CARD
        ══════════════════════════════════════════ */
        .table-card {
            border-radius: var(--radius);
            overflow: hidden;
            background: var(--glass);
            backdrop-filter: blur(24px) saturate(1.7);
            -webkit-backdrop-filter: blur(24px) saturate(1.7);
            border: 1px solid var(--border-g);
            box-shadow: var(--shadow-md), inset 0 1px 0 var(--glass-edge);
        }

        .table-head {
            padding: 18px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 1px solid var(--border-s);
            background: rgba(255,255,255,0.5);
        }

        .table-head-title {
            font-weight: 800;
            font-size: 15px;
            color: var(--text);
        }

        .table-count {
            font-size: 12px;
            font-weight: 600;
            color: var(--accent);
            background: rgba(79,110,247,0.08);
            border: 1px solid rgba(79,110,247,0.15);
            padding: 3px 11px;
            border-radius: 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead th {
            padding: 11px 20px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: var(--muted);
            border-bottom: 1px solid var(--border-s);
            white-space: nowrap;
            background: rgba(255,255,255,0.35);
        }

        tbody tr {
            border-bottom: 1px solid rgba(180,195,230,0.22);
            transition: background .15s;
        }

            tbody tr:last-child {
                border-bottom: none;
            }

            tbody tr:hover {
                background: rgba(255,255,255,0.55);
            }

            tbody tr.row-new td {
                animation: rowSlide .4s cubic-bezier(.4,0,.2,1);
            }

        td {
            padding: 14px 20px;
            vertical-align: middle;
        }

        /* AVATARS */
        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-weight: 700;
            color: #fff;
            box-shadow: 0 3px 10px rgba(0,0,0,0.15);
            border: 2px solid rgba(255,255,255,0.85);
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .user-detail .name {
            font-weight: 700;
            font-size: 13.5px;
            white-space: nowrap;
            color: var(--text);
        }

        .user-detail .date {
            font-size: 11.5px;
            color: var(--muted);
            margin-top: 1px;
        }

        /* REVIEW TEXT */
        .review-text {
            max-width: 230px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            font-size: 13px;
            color: var(--text-2);
            cursor: pointer;
            transition: color .15s;
        }

            .review-text:hover {
                color: var(--accent);
            }

        /* STARS */
        .stars {
            display: flex;
            gap: 1px;
        }

        .star-f {
            color: var(--amber);
            font-size: 14px;
            filter: drop-shadow(0 1px 2px rgba(245,158,11,0.4));
        }

        .star-e {
            color: rgba(100,116,139,0.25);
            font-size: 14px;
        }

        /* SENTIMENT BADGES */
        .badge-sentiment {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 5px 11px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            white-space: nowrap;
            backdrop-filter: blur(8px);
        }

            .badge-sentiment .dot {
                width: 6px;
                height: 6px;
                border-radius: 50%;
                flex-shrink: 0;
            }

        .badge-olumlu {
            background: rgba(16,185,129,0.13);
            color: #059669;
            border: 1px solid rgba(16,185,129,0.25);
        }

            .badge-olumlu .dot {
                background: var(--green);
                box-shadow: 0 0 6px var(--green);
            }

        .badge-olumsuz {
            background: rgba(239,68,68,0.11);
            color: #dc2626;
            border: 1px solid rgba(239,68,68,0.22);
        }

            .badge-olumsuz .dot {
                background: var(--red);
                box-shadow: 0 0 6px var(--red);
            }

        .badge-notr {
            background: rgba(100,116,139,0.10);
            color: #475569;
            border: 1px solid rgba(100,116,139,0.22);
        }

            .badge-notr .dot {
                background: var(--slate);
            }

        /* STATUS */
        .status-badge {
            padding: 4px 11px;
            border-radius: 20px;
            font-size: 11.5px;
            font-weight: 700;
            white-space: nowrap;
        }

        .status-active {
            background: rgba(16,185,129,0.12);
            color: #059669;
            border: 1px solid rgba(16,185,129,0.22);
        }

        .status-inactive {
            background: rgba(100,116,139,0.10);
            color: #64748b;
            border: 1px solid rgba(100,116,139,0.2);
        }

        /* ACTION BUTTONS */
        .btn-action {
            padding: 6px 13px;
            border-radius: var(--radius-sm);
            font-size: 12px;
            font-weight: 600;
            border: 1px solid transparent;
            cursor: pointer;
            transition: all .18s;
            font-family: 'DM Sans',sans-serif;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            white-space: nowrap;
            backdrop-filter: blur(8px);
        }

        .btn-rapor {
            background: rgba(79,110,247,0.1);
            color: var(--accent);
            border-color: rgba(79,110,247,0.22);
        }

            .btn-rapor:hover {
                background: var(--accent);
                color: white;
                box-shadow: 0 4px 14px rgba(79,110,247,0.35);
                transform: translateY(-1px);
            }

        .btn-analiz {
            background: rgba(245,158,11,0.1);
            color: #d97706;
            border-color: rgba(245,158,11,0.25);
        }

            .btn-analiz:hover {
                background: var(--amber);
                color: white;
                box-shadow: 0 4px 14px rgba(245,158,11,0.35);
                transform: translateY(-1px);
            }

        .btn-sil {
            background: rgba(239,68,68,0.09);
            color: var(--red);
            border-color: rgba(239,68,68,0.2);
        }

            .btn-sil:hover {
                background: var(--red);
                color: white;
                box-shadow: 0 4px 14px rgba(239,68,68,0.3);
                transform: translateY(-1px);
            }

        .btn-primary-solid {
            background: linear-gradient(135deg,#4f6ef7,#818cf8);
            color: white;
            border-color: transparent;
            box-shadow: 0 4px 14px rgba(79,110,247,0.35);
        }

            .btn-primary-solid:hover {
                background: linear-gradient(135deg,#3b5bdb,#6366f1);
                box-shadow: 0 6px 20px rgba(79,110,247,0.45);
                transform: translateY(-1px);
            }

        /* EMPTY STATE */
        .empty-state {
            padding: 64px 20px;
            text-align: center;
        }

        .empty-icon {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            background: rgba(79,110,247,0.09);
            border: 1px solid rgba(79,110,247,0.15);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            color: var(--accent);
            margin: 0 auto 16px;
        }

        .empty-title {
            font-weight: 700;
            font-size: 16px;
            margin-bottom: 6px;
        }

        .empty-sub {
            font-size: 13px;
            color: var(--muted);
        }

        /* MODALS */
        .modal-content {
            background: rgba(248,251,255,0.92) !important;
            backdrop-filter: blur(32px) saturate(2) !important;
            -webkit-backdrop-filter: blur(32px) saturate(2) !important;
            border: 1px solid var(--border-g) !important;
            border-radius: var(--radius) !important;
            box-shadow: var(--shadow-lg) !important;
            color: var(--text) !important;
            font-family: 'DM Sans', sans-serif;
        }

        .modal-header {
            border-bottom: 1px solid var(--border-s) !important;
            padding: 20px 24px !important;
            background: rgba(255,255,255,0.5);
        }

        .modal-footer {
            border-top: 1px solid var(--border-s) !important;
            padding: 16px 24px !important;
            background: rgba(255,255,255,0.4);
        }

        .modal-body {
            padding: 24px !important;
        }

        .modal-title {
            font-weight: 800;
            font-size: 16px;
        }

        .btn-close {
            opacity: .5;
        }

            .btn-close:hover {
                opacity: 1;
            }

        .analysis-block {
            background: rgba(255,255,255,0.65);
            border: 1px solid var(--border-s);
            border-radius: var(--radius-md);
            padding: 18px;
            margin-top: 18px;
            backdrop-filter: blur(8px);
        }

        .progress {
            background: rgba(180,195,230,0.25);
            height: 8px;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: inset 0 1px 2px rgba(0,0,0,0.05);
        }

        .progress-bar {
            transition: width .9s cubic-bezier(.4,0,.2,1);
            border-radius: 8px;
        }

        /* SCROLLBAR */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(79,110,247,0.2);
            border-radius: 10px;
        }

            ::-webkit-scrollbar-thumb:hover {
                background: rgba(79,110,247,0.4);
            }

        /* ANIMATIONS */
        @@keyframes rowSlide {
            from

        {
            opacity: 0;
            transform: translateY(-8px);
            background: rgba(79,110,247,0.08);
        }

        to {
            opacity: 1;
            transform: none;
            background: transparent;
        }

        }
        @@keyframes spin {
            to

        {
            transform: rotate(360deg);
        }

        }

        .analyzing-spin {
            display: inline-block;
            animation: spin .7s linear infinite;
        }
        @@keyframes fadeUp {
            from

        {
            opacity: 0;
            transform: translateY(16px);
        }

        to {
            opacity: 1;
            transform: none;
        }

        }

        .fade-up {
            animation: fadeUp .5s cubic-bezier(.4,0,.2,1) both;
        }

            .fade-up:nth-child(1) {
                animation-delay: .05s
            }

            .fade-up:nth-child(2) {
                animation-delay: .10s
            }

            .fade-up:nth-child(3) {
                animation-delay: .15s
            }

            .fade-up:nth-child(4) {
                animation-delay: .20s
            }

        /* RESPONSIVE */
        .menu-toggle {
            display: none;
        }

        .overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(15,23,42,0.35);
            z-index: 190;
            backdrop-filter: blur(4px);
        }
        @@media (max-width:991px) {
            .sidebar

        {
            transform: translateX(-100%);
        }

        .sidebar.open {
            transform: none;
        }

        .main-wrap {
            margin-left: 0;
        }

        .menu-toggle {
            display: flex;
        }

        }
        @@media (max-width:575px) {
            .main-content

        {
            padding: 18px;
        }

        .topbar {
            padding: 0 16px;
        }

        }
    </style>
</head>
<body>

