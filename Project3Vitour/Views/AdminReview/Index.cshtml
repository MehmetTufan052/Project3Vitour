                <div class="modal-body" style="padding:36px 28px">
                    <div style="width:60px;height:60px;background:rgba(239,68,68,0.11);border:1px solid rgba(239,68,68,0.22);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 18px;font-size:24px;color:var(--red)">
                        <i class="bi bi-trash3-fill"></i>
                    </div>
                    <div style="font-weight:800;font-size:17px;margin-bottom:8px;color:var(--text)">Yorumu Sil</div>
                    <div style="font-size:13px;color:var(--muted);margin-bottom:26px;line-height:1.6">Bu yorum kalıcı olarak silinecek.<br>Devam etmek istiyor musunuz?</div>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn-action btn-rapor" data-bs-dismiss="modal" style="padding:8px 20px">İptal</button>
                        <button class="btn-action btn-sil" id="confirmDeleteBtn" style="padding:8px 20px">Evet, Sil</button>
                    </div>
                </div>
