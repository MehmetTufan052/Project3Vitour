    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const reviews = [
          { id:1,  name:"Ayşe Kaya",      initials:"AK", gradient:"linear-gradient(135deg,#f59e0b,#ef4444)",   date:"12 Ocak 2025",  text:"Ürünü çok beğendim, kalitesi gerçekten mükemmel. Kesinlikle tavsiye ederim herkese!", stars:5, sentiment:"Olumlu",  score:92, status:"Aktif"  },
          { id:2,  name:"Mehmet Demir",   initials:"MD", gradient:"linear-gradient(135deg,#3b82f6,#6366f1)",   date:"14 Ocak 2025",  text:"Kargo çok geç geldi, paket hasarlıydı. Müşteri hizmetleri de yeterince ilgilenmedi.", stars:1, sentiment:"Olumsuz", score:8,  status:"Aktif"  },
          { id:3,  name:"Zeynep Şahin",   initials:"ZŞ", gradient:"linear-gradient(135deg,#10b981,#06b6d4)",   date:"15 Ocak 2025",  text:"Fiyat performans açısından makul. Ne çok iyi ne de çok kötü. Ortalama bir ürün.", stars:3, sentiment:"Nötr",    score:51, status:"Aktif"  },
          { id:4,  name:"Ali Çelik",      initials:"AÇ", gradient:"linear-gradient(135deg,#8b5cf6,#ec4899)",   date:"17 Ocak 2025",  text:"Harika bir deneyimdi! Tasarım şık, kullanım kolay. Çok memnunum bu alışverişten.", stars:5, sentiment:"Olumlu",  score:88, status:"Aktif"  },
          { id:5,  name:"Fatma Arslan",   initials:"FA", gradient:"linear-gradient(135deg,#f97316,#facc15)",   date:"18 Ocak 2025",  text:"Ürün açıklamasıyla uyuşmuyor, beklentimi karşılamadı. İade etmeyi düşünüyorum.", stars:2, sentiment:"Olumsuz", score:18, status:"Pasif"  },
          { id:6,  name:"Can Yılmaz",     initials:"CY", gradient:"linear-gradient(135deg,#14b8a6,#6366f1)",   date:"20 Ocak 2025",  text:"İdare eder bir ürün. Fiyatına göre kabul edilebilir, ancak daha iyisi bulunabilir.", stars:3, sentiment:"Nötr",    score:48, status:"Aktif"  },
          { id:7,  name:"Elif Koç",       initials:"EK", gradient:"linear-gradient(135deg,#ec4899,#f43f5e)",   date:"22 Ocak 2025",  text:"Süper hızlı kargo ve mükemmel ambalaj! Ürün tam istediğim gibiydi, teşekkürler.", stars:5, sentiment:"Olumlu",  score:95, status:"Aktif"  },
          { id:8,  name:"Burak Erdoğan",  initials:"BE", gradient:"linear-gradient(135deg,#0ea5e9,#22d3ee)",   date:"24 Ocak 2025",  text:"Ürün bozuk geldi. Garanti servisi de çok kötüydü. Asla tavsiye etmiyorum bu markayı.", stars:1, sentiment:"Olumsuz", score:4,  status:"Aktif"  },
          { id:9,  name:"Selin Öztürk",   initials:"SÖ", gradient:"linear-gradient(135deg,#a78bfa,#c084fc)",   date:"25 Ocak 2025",  text:"Genel olarak memnunum ama kargo biraz gecikmişti. Ürünün kendisi oldukça iyi.", stars:4, sentiment:"Olumlu",  score:73, status:"Aktif"  },
          { id:10, name:"Onur Aktaş",     initials:"OA", gradient:"linear-gradient(135deg,#34d399,#10b981)",   date:"26 Ocak 2025",  text:"Sipariş verirken çok sorun yaşadım ama ürün tamam. Karışık duygular içindeyim.", stars:3, sentiment:"Nötr",    score:55, status:"Pasif"  },
          { id:11, name:"Gül Aydın",      initials:"GA", gradient:"linear-gradient(135deg,#fb923c,#f59e0b)",   date:"27 Ocak 2025",  text:"Beklediğimden çok daha iyi! Kaliteli kumaş, güzel dikiş, tam beden uyumu.", stars:5, sentiment:"Olumlu",  score:97, status:"Aktif"  },
          { id:12, name:"Hasan Kılıç",    initials:"HK", gradient:"linear-gradient(135deg,#64748b,#475569)",   date:"28 Ocak 2025",  text:"Ürün normal, özel bir şey değil. Fiyatı biraz yüksek buldum ama kullanılabilir.", stars:3, sentiment:"Nötr",    score:44, status:"Aktif"  },
          { id:13, name:"Neslihan Baş",   initials:"NB", gradient:"linear-gradient(135deg,#e879f9,#c084fc)",   date:"29 Ocak 2025",  text:"Kesinlikle hayal kırıklığı! Para israfı. Asla tekrar almam, herkesi uyarıyorum.", stars:1, sentiment:"Olumsuz", score:5,  status:"Aktif"  },
          { id:14, name:"Tarık Şen",      initials:"TŞ", gradient:"linear-gradient(135deg,#22c55e,#16a34a)",   date:"30 Ocak 2025",  text:"Çok hızlı teslimat, ürün sağlam geldi ve beklentimi fazlasıyla karşıladı!", stars:5, sentiment:"Olumlu",  score:91, status:"Aktif"  },
          { id:15, name:"Pınar Doğan",    initials:"PD", gradient:"linear-gradient(135deg,#f43f5e,#fb7185)",   date:"31 Ocak 2025",  text:"Renk tam fotoğraftaki gibi değildi ama kalite iyiydi. Fiyatına değer sayılır.", stars:3, sentiment:"Nötr",    score:60, status:"Pasif"  },
        ];

        let pendingDeleteId = null;
        const rapportModal = new bootstrap.Modal(document.getElementById('rapportModal'));
        const deleteModal  = new bootstrap.Modal(document.getElementById('deleteModal'));

        function renderStars(n) {
          return Array.from({length:5},(_,i)=>`<span class="${i<n?'star-f':'star-e'}">${i<n?'★':'☆'}</span>`).join('');
        }
        function renderBadge(s, sc) {
          const m={Olumlu:'badge-olumlu',Olumsuz:'badge-olumsuz','Nötr':'badge-notr'};
          return `<span class="badge-sentiment ${m[s]||'badge-notr'}"><span class="dot"></span>${s}&nbsp;<strong>%${sc}</strong></span>`;
        }

        function renderTable() {
          const q   = document.getElementById('searchInput').value.toLowerCase();
          const sen = document.getElementById('filterSelect').value;
          const sta = document.getElementById('statusFilter').value;
          const list = reviews.filter(r =>
            (!q   || r.name.toLowerCase().includes(q) || r.text.toLowerCase().includes(q)) &&
            (!sen || r.sentiment === sen) &&
            (!sta || r.status === sta)
          );
          const tbody = document.getElementById('reviewTableBody');
          document.getElementById('tableCount').textContent = `${list.length} yorum`;
          if (!list.length) {
            tbody.innerHTML = '';
            document.getElementById('emptyState').classList.remove('d-none');
            updateStats(); return;
          }
          document.getElementById('emptyState').classList.add('d-none');
          tbody.innerHTML = list.map(r => `
            <tr id="row-${r.id}">
              <td>
                <div class="user-info">
                  <div class="user-avatar" style="background:${r.gradient}">${r.initials}</div>
                  <div class="user-detail"><div class="name">${r.name}</div><div class="date">${r.date}</div></div>
                </div>
              </td>
              <td><div class="review-text" title="${r.text}" onclick="showRapport(${r.id})">${r.text}</div></td>
              <td><div class="stars">${renderStars(r.stars)}</div></td>
              <td>${renderBadge(r.sentiment, r.score)}</td>
              <td><span class="status-badge ${r.status==='Aktif'?'status-active':'status-inactive'}">${r.status}</span></td>
              <td>
                <div class="d-flex gap-2 flex-wrap">
                  <button class="btn-action btn-rapor"  onclick="showRapport(${r.id})"><i class="bi bi-graph-up"></i> Rapor</button>
                  <button class="btn-action btn-analiz" onclick="analyzeOne(${r.id},this)"><i class="bi bi-cpu"></i></button>
                  <button class="btn-action btn-sil"    onclick="confirmDelete(${r.id})"><i class="bi bi-trash3"></i> Sil</button>
                </div>
              </td>
            </tr>`).join('');
          updateStats();
        }

        function updateStats() {
          const total   = reviews.length;
          const olumlu  = reviews.filter(r=>r.sentiment==='Olumlu').length;
          const olumsuz = reviews.filter(r=>r.sentiment==='Olumsuz').length;
          const notr    = reviews.filter(r=>r.sentiment==='Nötr').length;
          const pct = v => Math.round(v/total*100);
          document.getElementById('statTotal').textContent   = total;
          document.getElementById('statOlumlu').textContent  = olumlu;
          document.getElementById('statOlumsuz').textContent = olumsuz;
          document.getElementById('statNotr').textContent    = notr;
          document.getElementById('statOlumluPct').textContent  = `%${pct(olumlu)}`;
          document.getElementById('statOlumsuzPct').textContent = `%${pct(olumsuz)}`;
          document.getElementById('statNotrPct').textContent    = `%${pct(notr)}`;
          setTimeout(()=>{
            document.getElementById('barOlumlu').style.width  = pct(olumlu)+'%';
            document.getElementById('barOlumsuz').style.width = pct(olumsuz)+'%';
            document.getElementById('barNotr').style.width    = pct(notr)+'%';
          },100);
        }

        function showRapport(id) {
          const r = reviews.find(x=>x.id===id); if(!r) return;
          document.getElementById('modalUserInfo').innerHTML=`
            <div class="user-avatar" style="background:${r.gradient};width:50px;height:50px;font-size:16px">${r.initials}</div>
            <div><div style="font-weight:800;font-size:16px;color:var(--text)">${r.name}</div><div style="font-size:12px;color:var(--muted)">${r.date}</div></div>`;
          document.getElementById('modalReviewText').textContent = r.text;
          document.getElementById('modalSentimentBadge').innerHTML = renderBadge(r.sentiment,r.score);
          const bar = document.getElementById('modalProgressBar');
          bar.style.width='0%';
          bar.style.background = r.sentiment==='Olumlu' ? 'linear-gradient(90deg,#10b981,#34d399)'
            : r.sentiment==='Olumsuz' ? 'linear-gradient(90deg,#ef4444,#f87171)' : 'linear-gradient(90deg,#64748b,#94a3b8)';
          setTimeout(()=>{bar.style.width=r.score+'%';},120);
          document.getElementById('modalScoreText').textContent=`Analiz skoru: ${r.score} / 100`;
          document.getElementById('modalStars').innerHTML=`<div class="stars" style="font-size:18px">${renderStars(r.stars)}</div>`;
          const conf=r.score>80?'Yüksek':r.score>50?'Orta':'Düşük';
          const confC=r.score>80?'var(--green)':r.score>50?'var(--amber)':'var(--red)';
          document.getElementById('modalConfidence').innerHTML=`<span style="color:${confC}">${conf}</span>`;
          rapportModal.show();
        }

        function analyzeOne(id,btn) {
          const r=reviews.find(x=>x.id===id); if(!r) return;
          const orig=btn.innerHTML;
          btn.innerHTML='<span class="analyzing-spin"><i class="bi bi-arrow-repeat"></i></span>';
          btn.disabled=true;
          setTimeout(()=>{
            r.sentiment=['Olumlu','Olumsuz','Nötr'][Math.floor(Math.random()*3)];
            r.score=Math.floor(Math.random()*100)+1;
            btn.innerHTML=orig; btn.disabled=false;
            renderTable();
            const row=document.getElementById('row-'+id);
            if(row){row.classList.remove('row-new');void row.offsetWidth;row.classList.add('row-new');}
          },1300);
        }

        function analyzeAll() {
          const btn=document.getElementById('analyzeAllBtn');
          btn.innerHTML='<span class="analyzing-spin"><i class="bi bi-arrow-repeat"></i></span> Analiz Ediliyor...';
          btn.disabled=true;
          let i=0;
          const iv=setInterval(()=>{
            if(i>=reviews.length){clearInterval(iv);btn.innerHTML='<i class="bi bi-cpu-fill"></i> Tümünü Analiz Et';btn.disabled=false;renderTable();return;}
            reviews[i].sentiment=['Olumlu','Olumsuz','Nötr'][Math.floor(Math.random()*3)];
            reviews[i].score=Math.floor(Math.random()*100)+1;
            i++;
          },110);
        }

        function confirmDelete(id){pendingDeleteId=id;deleteModal.show();}
        document.getElementById('confirmDeleteBtn').addEventListener('click',()=>{
          if(pendingDeleteId===null)return;
          const idx=reviews.findIndex(r=>r.id===pendingDeleteId);
          if(idx>-1)reviews.splice(idx,1);
          pendingDeleteId=null;deleteModal.hide();renderTable();
        });

        document.getElementById('searchInput').addEventListener('input',renderTable);
        document.getElementById('filterSelect').addEventListener('change',renderTable);
        document.getElementById('statusFilter').addEventListener('change',renderTable);

        function toggleSidebar(){document.getElementById('sidebar').classList.toggle('open');document.getElementById('overlay').style.display='block';}
        function closeSidebar(){document.getElementById('sidebar').classList.remove('open');document.getElementById('overlay').style.display='none';}

        document.getElementById('todayDate').textContent=new Date().toLocaleDateString('tr-TR',{day:'numeric',month:'long',year:'numeric'});
        renderTable();
    </script>
</body>
</html>